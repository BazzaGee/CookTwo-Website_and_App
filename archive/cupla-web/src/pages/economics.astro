---
// src/pages/economics.astro - Internal Economics Analysis
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Cupla Economics — Internal Analysis</title>
  <meta name="robots" content="noindex, nofollow">
  <meta name="googlebot" content="noindex, nofollow">
  <meta name="description" content="Internal cost, pricing & profitability analysis for Cupla.">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <script is:inline src="https://cdn.tailwindcss.com"></script>
  <script is:inline>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            rose: {
              50: '#F5E6DC',
              100: '#F0D5C5',
              200: '#E8BF9F',
              500: '#C17D60',
              600: '#A5664A',
              700: '#8B4F3A',
              800: '#6E3D2D',
            },
            green: {
              50: '#E8F0E8',
              200: '#B8D0B8',
              500: '#8FA98F',
              600: '#7A9E7E',
              700: '#5D8A5F',
            },
            cream: {
              DEFAULT: '#FEF9F2',
              50: '#FFFDF9',
              100: '#F5E6D3',
            },
          },
          fontFamily: {
            sans: ['Inter', 'system-ui', 'sans-serif'],
          },
        },
      },
    }
  </script>
</head>
<body class="min-h-screen bg-cream text-slate-900 font-sans">

  <!-- Fixed Header -->
  <nav class="fixed top-0 w-full bg-cream/80 backdrop-blur-md border-b border-slate-200 z-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between items-center h-16">
        <a href="/" class="text-slate-600 hover:text-slate-900 transition">&larr; Back to Home</a>
        <span class="text-sm font-semibold text-slate-500 tracking-wide">CUPLA &middot; Internal Analysis</span>
      </div>
    </div>
  </nav>

  <main class="pt-16">

    <!-- Hero Section -->
    <section class="relative py-20 lg:py-24 px-4 overflow-hidden" style="background-image: radial-gradient(circle, #B8D0B8 1px, transparent 1px); background-size: 24px 24px;">
      <div class="max-w-4xl mx-auto text-center relative z-10">
        <h1 class="text-4xl sm:text-5xl font-bold text-slate-900 mb-4">Cupla Economics</h1>
        <p class="text-xl text-slate-600 mb-10">Internal Cost, Pricing &amp; Profitability Analysis</p>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
          <div class="bg-white rounded-xl shadow-md p-5">
            <p class="text-sm text-slate-500 mb-1">Monthly Sub Profit</p>
            <p class="text-2xl font-bold text-rose-500">NZ$6.06<span class="text-sm font-normal text-slate-400">/mo</span></p>
          </div>
          <div class="bg-white rounded-xl shadow-md p-5">
            <p class="text-sm text-slate-500 mb-1">Yearly Sub Profit</p>
            <p class="text-2xl font-bold text-rose-500">NZ$4.30<span class="text-sm font-normal text-slate-400">/mo</span></p>
          </div>
          <div class="bg-white rounded-xl shadow-md p-5">
            <p class="text-sm text-slate-500 mb-1">Blended Annual</p>
            <p class="text-2xl font-bold text-rose-500">NZ$64.26<span class="text-sm font-normal text-slate-400">/yr</span></p>
          </div>
          <div class="bg-white rounded-xl shadow-md p-5">
            <p class="text-sm text-slate-500 mb-1">Breakeven Conv</p>
            <p class="text-2xl font-bold text-rose-500">~4.7%</p>
          </div>
        </div>
        <p class="text-sm text-slate-400">Data verified: June 22, 2026 &middot; Based on actual Stripe data (NZ$0.73/sale fee)</p>
      </div>
    </section>

    <!-- Section 01: Pricing Tiers -->
    <section class="py-16 px-4">
      <div class="max-w-4xl mx-auto">
        <div class="flex items-center gap-3 mb-8">
          <span class="flex-shrink-0 w-10 h-10 rounded-full bg-rose-500 text-white flex items-center justify-center text-sm font-bold">01</span>
          <h2 class="text-2xl font-bold">Pricing Tiers</h2>
        </div>
        <div class="grid md:grid-cols-3 gap-6">
          <div class="bg-white border border-slate-200 rounded-xl p-6 shadow-sm">
            <h3 class="text-lg font-semibold text-slate-900 mb-1">Free</h3>
            <p class="text-3xl font-bold text-slate-900 mb-4">$0<span class="text-sm font-normal text-slate-400">/mo</span></p>
            <ul class="space-y-2 text-sm text-slate-600">
              <li class="flex justify-between"><span>Requests/day</span><span class="font-medium">10</span></li>
              <li class="flex justify-between"><span>Requests/month</span><span class="font-medium">300</span></li>
              <li class="flex justify-between border-t border-slate-100 pt-2 mt-2"><span>AI cost to Cupla</span><span class="font-medium text-rose-500">NZ$0.26/mo</span></li>
            </ul>
          </div>
          <div class="bg-white border-2 border-rose-500 rounded-xl p-6 shadow-md relative">
            <span class="absolute -top-3 left-4 bg-rose-500 text-white text-xs font-bold px-3 py-1 rounded-full">POPULAR</span>
            <h3 class="text-lg font-semibold text-slate-900 mb-1">Monthly</h3>
            <p class="text-3xl font-bold text-slate-900 mb-4">US$4.99<span class="text-sm font-normal text-slate-400">/mo</span></p>
            <ul class="space-y-2 text-sm text-slate-600">
              <li class="flex justify-between"><span>Requests/day</span><span class="font-medium">70</span></li>
              <li class="flex justify-between"><span>Requests/month</span><span class="font-medium">2,100</span></li>
              <li class="flex justify-between border-t border-slate-100 pt-2 mt-2"><span>AI cost</span><span class="font-medium text-rose-500">NZ$1.85/mo</span></li>
            </ul>
          </div>
          <div class="bg-white border border-slate-200 rounded-xl p-6 shadow-sm">
            <h3 class="text-lg font-semibold text-slate-900 mb-1">Yearly</h3>
            <p class="text-3xl font-bold text-slate-900 mb-4">US$44.99<span class="text-sm font-normal text-slate-400">/yr</span></p>
            <ul class="space-y-2 text-sm text-slate-600">
              <li class="flex justify-between"><span>Requests/day</span><span class="font-medium">70</span></li>
              <li class="flex justify-between"><span>Requests/month</span><span class="font-medium">2,100</span></li>
              <li class="flex justify-between border-t border-slate-100 pt-2 mt-2"><span>AI cost</span><span class="font-medium text-rose-500">NZ$1.85/mo</span></li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- Section 02: DeepSeek API Pricing -->
    <section class="py-16 px-4 bg-slate-50">
      <div class="max-w-4xl mx-auto">
        <div class="flex items-center gap-3 mb-8">
          <span class="flex-shrink-0 w-10 h-10 rounded-full bg-rose-500 text-white flex items-center justify-center text-sm font-bold">02</span>
          <h2 class="text-2xl font-bold">DeepSeek API Pricing</h2>
        </div>
        <div class="overflow-x-auto">
          <table class="w-full text-sm border border-slate-200 rounded-lg overflow-hidden">
            <thead class="bg-slate-100 text-slate-700">
              <tr>
                <th class="text-left px-4 py-3 font-semibold">Model</th>
                <th class="text-right px-4 py-3 font-semibold">Input (NZD)</th>
                <th class="text-right px-4 py-3 font-semibold">Output (NZD)</th>
                <th class="text-right px-4 py-3 font-semibold">Input (USD)</th>
                <th class="text-right px-4 py-3 font-semibold">Output (USD)</th>
              </tr>
            </thead>
            <tbody>
              <tr class="border-t border-slate-200 hover:bg-slate-50">
                <td class="px-4 py-3 font-medium">V4 Flash</td>
                <td class="px-4 py-3 text-right">NZ$0.24</td>
                <td class="px-4 py-3 text-right">NZ$0.48</td>
                <td class="px-4 py-3 text-right">US$0.14</td>
                <td class="px-4 py-3 text-right">US$0.28</td>
              </tr>
              <tr class="border-t border-slate-200 hover:bg-slate-50">
                <td class="px-4 py-3 font-medium">V4 Pro</td>
                <td class="px-4 py-3 text-right">NZ$0.75</td>
                <td class="px-4 py-3 text-right">NZ$1.49</td>
                <td class="px-4 py-3 text-right">US$0.44</td>
                <td class="px-4 py-3 text-right">US$0.87</td>
              </tr>
            </tbody>
          </table>
        </div>
        <p class="text-xs text-slate-400 mt-3">Per 1M tokens. Pricing as of June 14, 2026. NZD at FX 1.7148.</p>
        <div class="mt-6 bg-white rounded-xl p-5 border border-slate-200">
          <h4 class="font-semibold text-slate-700 mb-3">Per-Request Cost Summary</h4>
          <div class="grid sm:grid-cols-2 gap-4 text-sm">
            <div>
              <p class="text-slate-500">V4 Flash (base)</p>
              <p class="font-medium">NZ$0.00086 / US$0.00050 per request</p>
              <p class="text-xs text-slate-400 mt-1">With 2.5% card FX: NZ$0.00088</p>
            </div>
            <div>
              <p class="text-slate-500">V4 Pro (base)</p>
              <p class="font-medium">NZ$0.00257 / US$0.00150 per request</p>
              <p class="text-xs text-slate-400 mt-1">With 2.5% card FX: NZ$0.00263</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Section 03: DeepSeek vs OpenAI -->
    <section class="py-16 px-4">
      <div class="max-w-4xl mx-auto">
        <div class="flex items-center gap-3 mb-8">
          <span class="flex-shrink-0 w-10 h-10 rounded-full bg-rose-500 text-white flex items-center justify-center text-sm font-bold">03</span>
          <h2 class="text-2xl font-bold">DeepSeek vs OpenAI</h2>
        </div>
        <div class="bg-rose-50 border border-rose-200 rounded-xl p-5 mb-6">
          <p class="text-rose-700 font-semibold">DeepSeek V4 Flash is 94.7x cheaper than GPT-5.5</p>
        </div>
        <div class="overflow-x-auto">
          <table class="w-full text-sm border border-slate-200 rounded-lg overflow-hidden">
            <thead class="bg-slate-100 text-slate-700">
              <tr>
                <th class="text-left px-4 py-3 font-semibold">Metric</th>
                <th class="text-right px-4 py-3 font-semibold">DeepSeek V4 Flash</th>
                <th class="text-right px-4 py-3 font-semibold">GPT-5.5</th>
                <th class="text-right px-4 py-3 font-semibold">Ratio</th>
              </tr>
            </thead>
            <tbody>
              <tr class="border-t border-slate-200 hover:bg-slate-50">
                <td class="px-4 py-3 font-medium">Input cost per 1M tokens</td>
                <td class="px-4 py-3 text-right">NZ$0.24</td>
                <td class="px-4 py-3 text-right">NZ$22.72</td>
                <td class="px-4 py-3 text-right font-semibold text-rose-500">94.7x</td>
              </tr>
              <tr class="border-t border-slate-200 hover:bg-slate-50">
                <td class="px-4 py-3 font-medium">Output cost per 1M tokens</td>
                <td class="px-4 py-3 text-right">NZ$0.48</td>
                <td class="px-4 py-3 text-right">NZ$45.44</td>
                <td class="px-4 py-3 text-right font-semibold text-rose-500">94.7x</td>
              </tr>
              <tr class="border-t border-slate-200 bg-slate-50/50">
                <td class="px-4 py-3 font-medium" colspan="4">Cost Comparison &mdash; Free Tier (300 req/month)</td>
              </tr>
              <tr class="border-t border-slate-200 hover:bg-slate-50">
                <td class="px-4 py-3 pl-8">DeepSeek V4 Flash</td>
                <td class="px-4 py-3 text-right" colspan="2">NZ$0.26/month</td>
                <td class="px-4 py-3 text-right text-green-600 font-medium">Baseline</td>
              </tr>
              <tr class="border-t border-slate-200 hover:bg-slate-50">
                <td class="px-4 py-3 pl-8">GPT-5.5</td>
                <td class="px-4 py-3 text-right" colspan="2">NZ$24.27/month</td>
                <td class="px-4 py-3 text-right text-red-500 font-medium">93x more</td>
              </tr>
              <tr class="border-t border-slate-200 bg-slate-50/50">
                <td class="px-4 py-3 font-medium" colspan="4">Cost Comparison &mdash; Paid Tier (2,100 req/month)</td>
              </tr>
              <tr class="border-t border-slate-200 hover:bg-slate-50">
                <td class="px-4 py-3 pl-8">DeepSeek V4 Flash</td>
                <td class="px-4 py-3 text-right" colspan="2">NZ$1.85/month</td>
                <td class="px-4 py-3 text-right text-green-600 font-medium">Baseline</td>
              </tr>
              <tr class="border-t border-slate-200 hover:bg-slate-50">
                <td class="px-4 py-3 pl-8">GPT-5.5</td>
                <td class="px-4 py-3 text-right" colspan="2">NZ$174.05/month</td>
                <td class="px-4 py-3 text-right text-red-500 font-medium">94x more</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <!-- Section 04: Per-Couple Economics -->
    <section class="py-16 px-4 bg-slate-50">
      <div class="max-w-4xl mx-auto">
        <div class="flex items-center gap-3 mb-8">
          <span class="flex-shrink-0 w-10 h-10 rounded-full bg-rose-500 text-white flex items-center justify-center text-sm font-bold">04</span>
          <h2 class="text-2xl font-bold">Per-Couple Economics</h2>
        </div>
        <div class="bg-amber-50 border border-amber-200 rounded-xl p-4 mb-6">
          <p class="text-amber-800 text-sm"><strong>Current Reality:</strong> Stripe auto-converts USD&rarr;NZD (~2.1% conversion fee). AI costs paid from NZD card (+2.5% foreign transaction fee). See <a href="#section-14" class="text-rose-500 underline">Section 14</a> for optimized payment flow.</p>
        </div>
        <div class="grid md:grid-cols-3 gap-6 mb-8">
          <div class="bg-white border border-slate-200 rounded-xl p-6 shadow-sm">
            <h3 class="text-lg font-semibold text-slate-900 mb-4">Free Couple</h3>
            <div class="space-y-2 text-sm">
              <div class="flex justify-between"><span class="text-slate-500">Revenue</span><span class="font-medium">NZ$0.00/mo</span></div>
              <div class="flex justify-between"><span class="text-slate-500">AI cost (incl. card FX)</span><span class="font-medium text-rose-500">-NZ$0.26/mo</span></div>
              <div class="flex justify-between border-t border-slate-100 pt-2"><span class="font-semibold text-slate-900">Profit</span><span class="font-bold text-red-500">-NZ$0.26/mo</span></div>
              <div class="flex justify-between"><span class="text-slate-500">Annual</span><span class="font-medium text-red-500">-NZ$3.17/yr</span></div>
            </div>
          </div>
          <div class="bg-white border-2 border-rose-500 rounded-xl p-6 shadow-md">
            <h3 class="text-lg font-semibold text-slate-900 mb-4">Monthly Subscriber</h3>
            <div class="space-y-2 text-sm">
              <div class="flex justify-between"><span class="text-slate-500">Revenue (Stripe NZD)</span><span class="font-medium">NZ$8.64/mo</span></div>
              <div class="flex justify-between"><span class="text-slate-500">AI cost (incl. card FX)</span><span class="font-medium text-rose-500">-NZ$1.85/mo</span></div>
              <div class="flex justify-between"><span class="text-slate-500">Stripe fee (8.5%)</span><span class="font-medium text-rose-500">-NZ$0.73/mo</span></div>
              <div class="flex justify-between border-t border-slate-100 pt-2"><span class="font-semibold text-slate-900">Profit</span><span class="font-bold text-green-600">NZ$6.06/mo</span></div>
            </div>
          </div>
          <div class="bg-white border border-slate-200 rounded-xl p-6 shadow-sm">
            <h3 class="text-lg font-semibold text-slate-900 mb-4">Yearly Subscriber</h3>
            <div class="space-y-2 text-sm">
              <div class="flex justify-between"><span class="text-slate-500">Revenue</span><span class="font-medium">NZ$77.91/yr</span></div>
              <div class="flex justify-between"><span class="text-slate-500">AI cost (incl. card FX)</span><span class="font-medium text-rose-500">-NZ$22.14/yr</span></div>
              <div class="flex justify-between"><span class="text-slate-500">Stripe fee (5.4%)</span><span class="font-medium text-rose-500">-NZ$4.20/yr</span></div>
              <div class="flex justify-between border-t border-slate-100 pt-2"><span class="font-semibold text-slate-900">Profit</span><span class="font-bold text-green-600">NZ$51.57/yr</span></div>
              <div class="flex justify-between"><span class="text-slate-500">Monthly equiv.</span><span class="font-medium text-green-600">NZ$4.30/mo</span></div>
            </div>
          </div>
        </div>
        <div class="bg-white border border-slate-200 rounded-xl p-6 shadow-sm mb-6">
          <h4 class="font-semibold text-slate-900 mb-3">Blended Profit (60% Monthly / 40% Yearly)</h4>
          <p class="text-sm text-slate-600 mb-2">Monthly sub: 60% &times; NZ$72.72 = NZ$43.63/yr</p>
          <p class="text-sm text-slate-600 mb-2">Yearly Sub: 40% &times; NZ$51.57 = NZ$20.63/yr</p>
          <p class="text-lg font-bold text-rose-500 mt-3">Blended Annual Profit per Couple: NZ$64.26/yr (NZ$5.36/mo)</p>
        </div>
        <div class="bg-rose-50 border border-rose-200 rounded-xl p-5">
          <p class="text-rose-700 font-semibold">How many free couples does 1 paying couple subsidise?</p>
          <p class="text-rose-600 mt-1">NZ$5.36/mo profit &divide; NZ$0.26/mo free cost = <strong>~21 free couples</strong></p>
        </div>
      </div>
    </section>

    <!-- Section 05: Conversion Sensitivity Grid -->
    <section class="py-16 px-4">
      <div class="max-w-6xl mx-auto">
        <div class="flex items-center gap-3 mb-8">
          <span class="flex-shrink-0 w-10 h-10 rounded-full bg-rose-500 text-white flex items-center justify-center text-sm font-bold">05</span>
          <h2 class="text-2xl font-bold">Conversion Sensitivity Grid</h2>
        </div>
        <p class="text-sm text-slate-500 mb-4">Annual Gross Profit (NZD) &mdash; Includes real Stripe fees, card FX, and AI costs. Before CAC.</p>
        <div class="overflow-x-auto">
          <table class="w-full text-sm border border-slate-200 rounded-lg overflow-hidden text-right">
            <thead class="bg-slate-100 text-slate-700">
              <tr>
                <th class="text-left px-3 py-3 font-semibold">Couples</th>
                <th class="px-3 py-3 font-semibold">2%</th>
                <th class="px-3 py-3 font-semibold">3%</th>
                <th class="px-3 py-3 font-semibold">5%</th>
                <th class="px-3 py-3 font-semibold">8%</th>
                <th class="px-3 py-3 font-semibold bg-green-50">10%</th>
                <th class="px-3 py-3 font-semibold">12%</th>
                <th class="px-3 py-3 font-semibold">15%</th>
                <th class="px-3 py-3 font-semibold">20%</th>
              </tr>
            </thead>
            <tbody>
              <tr class="border-t border-slate-200 hover:bg-slate-50"><td class="text-left px-3 py-2 font-medium">100</td><td class="px-3 py-2 text-red-500">-$182</td><td class="px-3 py-2 text-red-500">-$115</td><td class="px-3 py-2 text-green-600">$20</td><td class="px-3 py-2 text-green-600">$222</td><td class="px-3 py-2 text-green-600 bg-green-50/50">$357</td><td class="px-3 py-2 text-green-600">$492</td><td class="px-3 py-2 text-green-600">$694</td><td class="px-3 py-2 text-green-600">$1,032</td></tr>
              <tr class="border-t border-slate-200 hover:bg-slate-50"><td class="text-left px-3 py-2 font-medium">500</td><td class="px-3 py-2 text-red-500">-$911</td><td class="px-3 py-2 text-red-500">-$574</td><td class="px-3 py-2 text-green-600">$101</td><td class="px-3 py-2 text-green-600">$1,112</td><td class="px-3 py-2 text-green-600 bg-green-50/50">$1,787</td><td class="px-3 py-2 text-green-600">$2,461</td><td class="px-3 py-2 text-green-600">$3,472</td><td class="px-3 py-2 text-green-600">$5,158</td></tr>
