---
// src/pages/index.astro - Landing Page
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>CookTwo - Plan Life Together</title>
  <meta name="description" content="The shared calendar and planning app for couples. Stay organized, plan dates, and never miss a moment.">
</head>
<body class="min-h-screen bg-white text-slate-900">
  <nav class="fixed top-0 w-full bg-white/80 backdrop-blur-md border-b border-slate-200 z-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between items-center h-16">
        <div class="flex items-center">
          <span class="text-2xl font-bold text-rose-500">CookTwo</span>
        </div>
        <div class="flex items-center gap-4">
          <a href="/auth/login" class="text-slate-600 hover:text-slate-900">Sign In</a>
          <a href="/auth/signup" class="bg-rose-500 text-white px-4 py-2 rounded-lg hover:bg-rose-600 transition">
            Get Started
          </a>
        </div>
      </div>
    </div>
  </nav>

  <main class="pt-16">
    <!-- Hero Section -->
    <section class="py-20 lg:py-32 px-4">
      <div class="max-w-4xl mx-auto text-center">
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-slate-900 mb-6">
          Plan Life Together
        </h1>
        <p class="text-xl text-slate-600 mb-8 max-w-2xl mx-auto">
          The shared calendar and planning app for couples. 
          Stay organized, plan dates, and never miss a moment with your partner.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/auth/signup" class="bg-rose-500 text-white px-8 py-4 rounded-xl text-lg font-semibold hover:bg-rose-600 transition">
            Start Free
          </a>
          <a href="#features" class="bg-slate-100 text-slate-700 px-8 py-4 rounded-xl text-lg font-semibold hover:bg-slate-200 transition">
            Learn More
          </a>
        </div>
      </div>
    </section>

    <!-- Features Section -->
    <section id="features" class="py-20 px-4 bg-slate-50">
      <div class="max-w-6xl mx-auto">
        <h2 class="text-3xl font-bold text-center mb-12">Everything You Need</h2>
        <div class="grid md:grid-cols-3 gap-8">
          <div class="bg-white p-6 rounded-xl shadow-sm">
            <div class="w-12 h-12 bg-rose-100 rounded-lg flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-rose-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
            </div>
            <h3 class="text-xl font-semibold mb-2">Shared Calendar</h3>
            <p class="text-slate-600">See both your schedules in one place. Google and Outlook integration included.</p>
          </div>
          
          <div class="bg-white p-6 rounded-xl shadow-sm">
            <div class="w-12 h-12 bg-rose-100 rounded-lg flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-rose-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
              </svg>
            </div>
            <h3 class="text-xl font-semibold mb-2">To-Do Lists</h3>
            <p class="text-slate-600">Shared tasks and grocery lists. Assign to each other and track completion.</p>
          </div>
          
          <div class="bg-white p-6 rounded-xl shadow-sm">
            <div class="w-12 h-12 bg-rose-100 rounded-lg flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-rose-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
              </svg>
            </div>
            <h3 class="text-xl font-semibold mb-2">Date Planner</h3>
            <p class="text-slate-600">Set date goals and get reminders. Keep your relationship a priority.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="py-20 px-4">
      <div class="max-w-4xl mx-auto text-center">
        <h2 class="text-3xl font-bold mb-4">Ready to Get Organized?</h2>
        <p class="text-xl text-slate-600 mb-8">Join thousands of couples already using CookTwo.</p>
        <a href="/auth/signup" class="bg-rose-500 text-white px-8 py-4 rounded-xl text-lg font-semibold hover:bg-rose-600 transition">
          Get Started Free
        </a>
      </div>
    </section>
  </main>

  <footer class="bg-slate-900 text-slate-400 py-12 px-4">
    <div class="max-w-6xl mx-auto text-center">
      <p>&copy; 2025 CookTwo. Built for couples.</p>
    </div>
  </footer>
</body>
</html>
