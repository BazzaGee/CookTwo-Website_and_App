---
// src/pages/app/key-dates.astro
import AppLayout from '../../layouts/AppLayout.astro';

export const prerender = false;
---

<AppLayout>
  <div class="p-6 max-w-4xl mx-auto">
    <div class="flex items-center justify-between mb-6">
      <div>
        <h1 class="text-2xl font-bold text-slate-900">Key Dates</h1>
        <p class="text-slate-600">Never miss a special moment</p>
      </div>
      <button id="add-key-date-btn" class="px-4 py-2 bg-rose-500 text-white rounded-lg hover:bg-rose-600 transition flex items-center gap-2">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
        </svg>
        Add Key Date
      </button>
    </div>
    
    <!-- Countdown Cards -->
    <div id="countdown-container" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 mb-8">
      <!-- Countdowns will be loaded here -->
    </div>
    
    <!-- All Key Dates -->
    <div class="bg-white rounded-xl p-6 shadow-sm border border-slate-200">
      <h2 class="text-lg font-semibold mb-4">All Dates</h2>
      <div id="key-dates-list" class="divide-y divide-slate-100">
        <div class="text-center text-slate-500 py-8">No key dates yet</div>
      </div>
    </div>
  </div>

  <!-- Add Key Date Modal -->
  <div id="key-date-modal" class="fixed inset-0 bg-black/50 hidden items-center justify-center z-50">
    <div class="bg-white rounded-xl p-6 w-full max-w-md">
      <h2 class="text-xl font-bold mb-4">Add Key Date</h2>
      <form id="key-date-form" class="space-y-4">
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1">Title</label>
          <input type="text" id="key-date-title" placeholder="e.g., Our Anniversary" required
            class="w-full px-3 py-2 border rounded-lg focus:ring-2 focus:ring-rose-500 outline-none">
        </div>
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1">Date</label>
          <input type="date" id="key-date-date" required
            class="w-full px-3 py-2 border rounded-lg focus:ring-2 focus:ring-rose-500 outline-none">
        </div>
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1">Type</label>
          <select id="key-date-type" class="w-full px-3 py-2 border rounded-lg focus:ring-2 focus:ring-rose-500 outline-none">
            <option value="anniversary">Anniversary</option>
            <option value="birthday">Birthday</option>
            <option value="trip">Trip</option>
            <option value="milestone">Milestone</option>
            <option value="other">Other</option>
          </select>
        </div>
        <div class="flex items-center gap-2">
          <input type="checkbox" id="key-date-recurring" class="rounded border-slate-300 text-rose-500 focus:ring-rose-500">
          <label for="key-date-recurring" class="text-sm text-slate-700">Repeats yearly</label>
        </div>
        <div class="flex gap-3 pt-2">
          <button type="button" id="cancel-key-date" class="flex-1 px-4 py-2 border rounded-lg hover:bg-slate-50">Cancel</button>
          <button type="submit" class="flex-1 px-4 py-2 bg-rose-500 text-white rounded-lg hover:bg-rose-600">Save</button>
        </div>
      </form>
    </div>
  </div>

  <script>
    import { supabase } from '../../lib/supabase/client';
    
    let coupleId;
    
    async function init() {
      const { data: { user } } = await supabase.auth.getUser();
      if (!user) return;
      
      const { data: profile } = await supabase
        .from('profiles')
        .select('partner_id')
        .eq('id', user.id)
        .single();
      
      if (!profile?.partner_id) return;
      
      coupleId = [user.id, profile.partner_id].sort().join('-');
      
      await loadKeyDates();
    }
    
    async function loadKeyDates() {
      const { data: keyDates } = await supabase
        .from('key_dates')
        .select('*')
        .eq('couple_id', coupleId)
        .order('date', { ascending: true });
      
      const container = document.getElementById('key-dates-list');
      const countdownContainer = document.getElementById('countdown-container');
      
      if (!keyDates?.length) {
        container.innerHTML = '<div class="text-center text-slate-500 py-8">No key dates yet</div>';
        countdownContainer.innerHTML = '';
        return;
      }
      
      // All dates list
      container.innerHTML = keyDates.map(date => `
        <div class="flex items-center justify-between py-3">
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-full ${getTypeColor(date.date_type)} flex items-center justify-center text-white">
              ${getTypeIcon(date.date_type)}
            </div>
            <div>
              <p class="font-medium text-slate-900">${date.title}</p>
              <p class="text-sm text-slate-500">${new Date(date.date).toLocaleDateString()}</p>
            </div>
          </div>
          <div class="flex items-center gap-4">
            <span class="text-rose-600 font-semibold">${getDaysUntil(date.date)} days</span>
            <button onclick="deleteKeyDate('${date.id}')" class="text-slate-400 hover:text-red-500">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
              </svg>
            </button>
          </div>
        </div>
      `).join('');
      
      // Countdown cards (upcoming only)
      const upcoming = keyDates.filter(d => getDaysUntil(d.date) >= 0).slice(0, 6);
      countdownContainer.innerHTML = upcoming.map(date => `
        <div class="bg-white rounded-xl p-4 shadow-sm border border-slate-200 text-center">
          <div class="text-4xl font-bold text-rose-500 mb-1">${getDaysUntil(date.date)}</div>
          <div class="text-sm text-slate-600 mb-2">days until</div>
          <h3 class="font-semibold text-slate-900">${date.title}</h3>
          <p class="text-xs text-slate-500 mt-1">${new Date(date.date).toLocaleDateString()}</p>
        </div>
      `).join('');
    }
    
    function getTypeColor(type) {
      const colors = {
        anniversary: 'bg-rose-500',
        birthday: 'bg-purple-500',
        trip: 'bg-blue-500',
        milestone: 'bg-amber-500',
        other: 'bg-slate-500',
      };
      return colors[type] || colors.other;
    }
    
    function getTypeIcon(type) {
      const icons = {
        anniversary: '♥',
        birthday: '🎂',
        trip: '✈',
        milestone: '🏆',
        other: '📅',
      };
      return icons[type] || icons.other;
    }
    
    function getDaysUntil(dateStr) {
      const date = new Date(dateStr);
      const today = new Date();
      today.setHours(0, 0, 0, 0);
      date.setHours(0, 0, 0, 0);
      
      if (date < today) {
        // For recurring dates, calculate next occurrence
        date.setFullYear(today.getFullYear());
        if (date < today) {
          date.setFullYear(today.getFullYear() + 1);
        }
      }
      
      const diff = date - today;
      return Math.ceil(diff / (1000 * 60 * 60 * 24));
    }
    
    window.deleteKeyDate = async (id) => {
      await supabase.from('key_dates').delete().eq('id', id);
      loadKeyDates();
    };
    
    // Modal handlers
    document.getElementById('add-key-date-btn')?.addEventListener('click', () => {
      document.getElementById('key-date-modal').classList.remove('hidden');
      document.getElementById('key-date-modal').classList.add('flex');
    });
    
    document.getElementById('cancel-key-date')?.addEventListener('click', () => {
      document.getElementById('key-date-modal').classList.add('hidden');
      document.getElementById('key-date-modal').classList.remove('flex');
    });
    
    document.getElementById('key-date-form')?.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      const { data: { user } } = await supabase.auth.getUser();
      
      const { error } = await supabase.from('key_dates').insert([{
        couple_id: coupleId,
        created_by: user.id,
        title: document.getElementById('key-date-title').value,
        date: document.getElementById('key-date-date').value,
        date_type: document.getElementById('key-date-type').value,
        is_recurring: document.getElementById('key-date-recurring').checked,
      }]);
      
      if (!error) {
        document.getElementById('key-date-modal').classList.add('hidden');
        document.getElementById('key-date-modal').classList.remove('flex');
        document.getElementById('key-date-form').reset();
        loadKeyDates();
      }
    });
    
    init();
  </script>
</AppLayout>
