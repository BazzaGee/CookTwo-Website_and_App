---
// src/pages/app/ai.astro
import AppLayout from '../../layouts/AppLayout.astro';

export const prerender = false;
---

<AppLayout>
  <div class="h-screen flex flex-col max-w-4xl mx-auto">
    <!-- Header -->
    <div class="bg-white border-b border-slate-200 px-6 py-4 flex items-center gap-3">
      <div class="w-10 h-10 rounded-full bg-rose-100 flex items-center justify-center">
        <svg class="w-6 h-6 text-rose-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
        </svg>
      </div>
      <div>
        <h2 class="font-semibold text-slate-900">CookTwo AI</h2>
        <p class="text-xs text-slate-500">Your relationship assistant</p>
      </div>
    </div>
    
    <!-- Quick Actions -->
    <div class="bg-slate-50 px-6 py-4 border-b border-slate-200">
      <p class="text-sm text-slate-600 mb-3">Quick actions:</p>
      <div class="flex flex-wrap gap-2">
        <button onclick="setPrompt('Plan a date for this weekend')" class="px-3 py-1.5 bg-white border border-slate-300 rounded-full text-sm hover:bg-slate-100 transition">
          📅 Plan a date
        </button>
        <button onclick="setPrompt('Find when we are both free this week')" class="px-3 py-1.5 bg-white border border-slate-300 rounded-full text-sm hover:bg-slate-100 transition">
          ⏰ Find free time
        </button>
        <button onclick="setPrompt('Help me organize: we need groceries, I have a dentist appointment Tuesday, and we should plan a movie night')" class="px-3 py-1.5 bg-white border border-slate-300 rounded-full text-sm hover:bg-slate-100 transition">
          📝 Brain dump
        </button>
        <button onclick="setPrompt('Suggest some romantic date ideas')" class="px-3 py-1.5 bg-white border border-slate-300 rounded-full text-sm hover:bg-slate-100 transition">
          💡 Date ideas
        </button>
      </div>
    </div>
    
    <!-- Chat Messages -->
    <div id="chat-messages" class="flex-1 overflow-y-auto p-6 space-y-4">
      <div class="flex justify-start">
        <div class="max-w-md bg-rose-50 border border-rose-100 rounded-2xl px-4 py-3">
          <p class="text-slate-700">Hi! I'm CookTwo AI. I can help you:</p>
          <ul class="text-sm text-slate-600 mt-2 space-y-1">
            <li>• Plan dates and find free time</li>
            <li>• Turn your thoughts into organized tasks</li>
            <li>• Suggest date ideas and activities</li>
          </ul>
          <p class="text-slate-700 mt-2">What would you like help with today?</p>
        </div>
      </div>
    </div>
    
    <!-- Input -->
    <div class="bg-white border-t border-slate-200 p-4">
      <form id="ai-form" class="flex items-end gap-3">
        <div class="flex-1">
          <textarea 
            id="ai-input" 
            rows="2"
            placeholder="Ask CookTwo AI anything..."
            class="w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-rose-500 focus:border-rose-500 outline-none resize-none"
          ></textarea>
        </div>
        <button type="submit" id="send-btn" class="px-6 py-2 bg-rose-500 text-white rounded-lg font-semibold hover:bg-rose-600 transition">
          Send
        </button>
      </form>
    </div>
  </div>

  <script>
    import { supabase } from '../../lib/supabase/client';
    
    let coupleId;
    let currentUserId;
    let isLoading = false;
    
    async function init() {
      const { data: { user } } = await supabase.auth.getUser();
      if (!user) return;
      
      currentUserId = user.id;
      
      const { data: profile } = await supabase
        .from('profiles')
        .select('partner_id')
        .eq('id', user.id)
        .single();
      
      if (!profile?.partner_id) return;
      
      coupleId = [user.id, profile.partner_id].sort().join('-');
    }
    
    window.setPrompt = (text) => {
      document.getElementById('ai-input').value = text;
      document.getElementById('ai-input').focus();
    };
    
    async function getContext() {
      // Get upcoming events
      const { data: events } = await supabase
        .from('events')
        .select('*')
        .eq('couple_id', coupleId)
        .gte('start_time', new Date().toISOString())
        .lte('start_time', new Date(Date.now() + 14 * 24 * 60 * 60 * 1000).toISOString())
        .order('start_time', { ascending: true });
      
      // Get pending todos
      const { data: todos } = await supabase
        .from('todos')
        .select('*')
        .eq('couple_id', coupleId)
        .eq('is_completed', false)
        .limit(10);
      
      return {
        upcoming_events: events?.map(e => ({
          title: e.title,
          start: e.start_time,
          end: e.end_time,
        })) || [],
        pending_todos: todos?.map(t => t.title) || [],
        current_date: new Date().toISOString(),
      };
    }
    
    function addMessage(content, isUser = false) {
      const container = document.getElementById('chat-messages');
      const div = document.createElement('div');
      div.className = `flex ${isUser ? 'justify-end' : 'justify-start'}`;
      div.innerHTML = `
        <div class="max-w-md ${isUser ? 'bg-rose-500 text-white' : 'bg-white border border-slate-200'} rounded-2xl px-4 py-3 shadow-sm">
          <p class="whitespace-pre-wrap">${content}</p>
        </div>
      `;
      container.appendChild(div);
      container.scrollTop = container.scrollHeight;
    }
    
    function addLoading() {
      const container = document.getElementById('chat-messages');
      const div = document.createElement('div');
      div.id = 'loading-message';
      div.className = 'flex justify-start';
      div.innerHTML = `
        <div class="max-w-md bg-white border border-slate-200 rounded-2xl px-4 py-3 shadow-sm">
          <div class="flex items-center gap-2 text-slate-500">
            <svg class="animate-spin w-5 h-5" fill="none" viewBox="0 0 24 24">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
            </svg>
            <span>Thinking...</span>
          </div>
        </div>
      `;
      container.appendChild(div);
      container.scrollTop = container.scrollHeight;
    }
    
    function removeLoading() {
      const loading = document.getElementById('loading-message');
      if (loading) loading.remove();
    }
    
    document.getElementById('ai-form')?.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      const input = document.getElementById('ai-input');
      const message = input.value.trim();
      if (!message || isLoading) return;
      
      // Add user message
      addMessage(message, true);
      input.value = '';
      
      // Show loading
      isLoading = true;
      const btn = document.getElementById('send-btn');
      btn.disabled = true;
      btn.textContent = '...';
      addLoading();
      
      try {
        // Get context
        const context = await getContext();
        
        // Call API
        const response = await fetch('/api/ai/chat', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            messages: [{ role: 'user', content: message }],
            context,
          }),
        });
        
        const data = await response.json();
        
        removeLoading();
        
        if (data.choices?.[0]?.message?.content) {
          addMessage(data.choices[0].message.content);
        } else {
          addMessage('Sorry, I had trouble processing that. Please try again.');
        }
      } catch (error) {
        removeLoading();
        addMessage('Sorry, something went wrong. Please try again.');
      } finally {
        isLoading = false;
        btn.disabled = false;
        btn.textContent = 'Send';
      }
    });
    
    // Enter key to send
    document.getElementById('ai-input')?.addEventListener('keypress', (e) => {
      if (e.key === 'Enter' && !e.shiftKey) {
        e.preventDefault();
        document.getElementById('ai-form').dispatchEvent(new Event('submit'));
      }
    });
    
    init();
  </script>
</AppLayout>
