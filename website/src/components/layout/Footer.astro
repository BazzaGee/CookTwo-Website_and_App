---
import navigation from '../../data/navigation.json';
import EarlyAccessButton from '../forms/EarlyAccessButton.astro';
const { product, company } = navigation.navigation.footer;
const currentYear = new Date().getFullYear();
---

<footer class="py-16 bg-cream-dark border-t border-border">
  <div class="max-w-6xl mx-auto px-6">
    <div class="text-center mb-12 pb-12 border-b border-border">
      <h3 class="text-2xl font-bold text-text-primary mb-3">Get early access to CookTwo</h3>
      <p class="text-text-secondary mb-6 max-w-md mx-auto">One shared kitchen for the two of you &mdash; sync your list, stock your pantry, and let AI plate dinner two ways.</p>
      <div class="flex justify-center">
        <EarlyAccessButton variant="primary" />
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <div class="md:col-span-2">
        <a href="/" class="font-semibold text-xl flex items-center gap-2 mb-4 tracking-tight text-text-primary">
          <img src="/images/logo/logo-icon.png" alt="CookTwo logo" class="w-6 h-6" decoding="async" />
          CookTwo
        </a>
        <p class="max-w-sm text-lg text-text-secondary">
          One dinner. Two plates. Zero arguments. The collaborative adaptive nutrition app for couples with different dietary goals.
        </p>
        <div class="mt-6">
          <p class="text-sm font-semibold mb-2 text-text-primary">Built With</p>
          <div class="flex flex-wrap gap-2">
            <span class="text-xs px-2.5 py-1 rounded-full bg-sage/10 text-sage font-medium">React 19</span>
            <span class="text-xs px-2.5 py-1 rounded-full bg-sage/10 text-sage font-medium">Cloudflare Workers</span>
            <span class="text-xs px-2.5 py-1 rounded-full bg-sage/10 text-sage font-medium">D1 Database</span>
            <span class="text-xs px-2.5 py-1 rounded-full bg-sage/10 text-sage font-medium">Durable Objects</span>
            <span class="text-xs px-2.5 py-1 rounded-full bg-sage/10 text-sage font-medium">PWA</span>
          </div>
        </div>
      </div>
      <div>
        <h4 class="font-semibold mb-4 text-lg text-text-primary">Product</h4>
        <ul class="space-y-3">
          {product.map((item) => (
            <li><a href={item.href} class="text-text-secondary hover:text-sage transition-colors">{item.label}</a></li>
          ))}
        </ul>
        <h4 class="font-semibold mb-4 mt-8 text-lg text-text-primary">Company</h4>
        <ul class="space-y-3">
          {company.map((item) => (
            <li><a href={item.href} class="text-text-secondary hover:text-sage transition-colors">{item.label}</a></li>
          ))}
        </ul>
      </div>
    </div>
    <div class="max-w-6xl mx-auto mt-16 pt-8 border-t text-center border-border text-text-secondary">
      &copy; {currentYear} CookTwo. All rights reserved.
    </div>
  </div>
</footer>
