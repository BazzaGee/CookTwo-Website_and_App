---
import navigation from '../../data/navigation.json';
import EarlyAccessButton from '../forms/EarlyAccessButton.astro';
const { primary } = navigation.navigation;
const chevron = '<svg class="w-3.5 h-3.5 transition-transform group-hover:rotate-180" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>';
---

<header class="fixed top-0 w-full z-50 bg-cream/90 backdrop-blur-md border-b border-border">
  <div class="max-w-6xl mx-auto px-6 h-20 flex items-center justify-between">
    <a href="/" class="flex items-center gap-2 transition-colors text-text-primary hover:text-sage">
      <img src="/images/logo/logo-icon.png" alt="CookTwo logo" class="w-8 h-8" decoding="async" fetchpriority="high" />
      <span class="font-semibold text-xl tracking-tight">CookTwo</span>
    </a>

    <nav class="hidden md:flex items-center gap-6 font-medium">
      {primary.map((item) => (
        item.children ? (
          <div class="relative group">
            <a href={item.href} class="flex items-center gap-1 text-text-secondary hover:text-sage transition-colors py-2">
              {item.label}
              <span set:html={chevron} />
            </a>
            <div class="absolute left-1/2 -translate-x-1/2 top-full pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-150 z-50">
              <div class="bg-white rounded-xl border border-border shadow-lg py-2 min-w-[220px]">
                {item.children.map((child) => (
                  <a href={child.href} class="block px-4 py-2 text-sm text-text-secondary hover:text-sage hover:bg-cream transition-colors">{child.label}</a>
                ))}
              </div>
            </div>
          </div>
        ) : (
          <a href={item.href} class="text-text-secondary hover:text-sage transition-colors">{item.label}</a>
        )
      ))}
    </nav>

    <div class="hidden lg:flex items-center gap-2">
      <EarlyAccessButton variant="nav" />
    </div>

    <button id="mobile-menu-btn" class="md:hidden text-text-primary" aria-label="Toggle Menu">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" x2="20" y1="12" y2="12"/><line x1="4" x2="20" y1="6" y2="6"/><line x1="4" x2="20" y1="18" y2="18"/></svg>
    </button>
  </div>

  <div id="mobile-menu" class="hidden md:hidden border-t px-6 py-4 flex flex-col gap-3 text-lg font-medium shadow-lg bg-cream border-border">
    {primary.map((item) => (
      <div>
        <a href={item.href} class="block text-text-secondary hover:text-sage py-1">{item.label}</a>
        {item.children && (
          <div class="ml-4 mt-1 mb-2 flex flex-col gap-1 border-l border-border pl-3">
            {item.children.map((child) => (
              <a href={child.href} class="text-sm text-text-secondary/80 hover:text-sage">{child.label}</a>
            ))}
          </div>
        )}
      </div>
    ))}
    <div class="mt-2 pt-4 border-t border-border">
      <EarlyAccessButton variant="primary" class="w-full" />
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>
