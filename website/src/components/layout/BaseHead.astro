---
interface Props {
  title: string;
  description: string;
  canonicalURL?: string;
  ogImage?: string;
}

const { title, description, canonicalURL, ogImage } = Astro.props;
const siteURL = 'https://cooktwo.com';
const canonical = canonicalURL ? `${siteURL}${canonicalURL}` : Astro.url;
const ogImg = ogImage || `${siteURL}/images/hero/og-homepage.webp`;

const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "CookTwo",
  "url": "https://cooktwo.com",
  "logo": "https://cooktwo.com/images/logo/logo-icon.png",
  "description": "Collaborative adaptive nutrition app for couples — one meal, two plates.",
  "foundingDate": "2025",
  "founder": {
    "@type": "Person",
    "name": "Barry"
  }
};

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "CookTwo",
  "url": "https://cooktwo.com",
  "description": "Collaborative adaptive nutrition app for couples."
};
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="generator" content={Astro.generator} />

<title>{title}</title>
<meta name="description" content={description} />
<meta name="keywords" content="couples meal planning, shared grocery list, adaptive cooking, meal planning for couples, pantry AI, CookTwo, collaborative nutrition, two plates" />
<meta name="author" content="CookTwo" />
<meta name="robots" content="index, follow" />

<link rel="canonical" href={canonical} />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />

<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:type" content="website" />
<meta property="og:url" content={canonical} />
<meta property="og:image" content={ogImg} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:locale" content="en_US" />
<meta property="og:site_name" content="CookTwo" />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImg} />

<link rel="manifest" href="/manifest.json" />
<meta name="theme-color" content="#7A9E7E" />
<meta name="apple-mobile-web-app-capable" content="yes" />
<meta name="apple-mobile-web-app-status-bar-style" content="default" />
<meta name="apple-mobile-web-app-title" content="CookTwo" />

<meta name="googlebot" content="index, follow" />

<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="apple-touch-icon" href="/images/logo/logo-icon.png" />

<!-- Cloudflare Web Analytics — beacon token replaced in Phase 4 with the real token from the CF Pages project settings -->
<script defer src="https://static.cloudflareinsights.com/beacon.min.js" data-cf-beacon='{"token": "PLACEHOLDER_REPLACE_IN_PHASE_4"}'></script>

<!-- Google Analytics (gtag.js) -->
<script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-VVZFC3RYZ7"></script>
<script is:inline>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());
  gtag('config', 'G-VVZFC3RYZ7');
</script>

<script type="application/ld+json" set:html={JSON.stringify(organizationSchema)}></script>
<script type="application/ld+json" set:html={JSON.stringify(websiteSchema)}></script>
