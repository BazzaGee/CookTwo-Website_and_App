---
interface Props { appName?: string }
const { appName = 'CookTwo' } = Astro.props;
---

<div class="bg-white rounded-2xl border border-border overflow-hidden shadow-sm">
  <div class="px-4 py-3 border-b border-border flex items-center justify-between">
    <div class="flex items-center gap-2">
      <div class="w-6 h-6 rounded-lg bg-sage"></div>
      <span class="text-sm font-semibold text-text-primary">{appName}</span>
    </div>
    <span class="text-xs text-text-secondary">Adaptive Cooking</span>
  </div>

  <div class="px-4 py-3 border-b border-border">
    <div class="flex items-center justify-between">
      <div>
        <h3 class="font-semibold text-text-primary">Chicken &amp; Tofu Stir-Fry</h3>
        <p class="text-xs text-text-secondary">One recipe · Two plates · 25 min</p>
      </div>
      <div class="text-xs font-medium text-sage bg-sage/10 px-2 py-1 rounded-full">AI Adapted</div>
    </div>
  </div>

  <div class="px-4 py-3 border-b border-border">
    <p class="text-xs font-semibold text-text-primary mb-2">Cooking steps — shared:</p>
    <div class="space-y-1.5">
      <div class="flex items-start gap-2"><span class="text-xs font-bold text-sage">1.</span><span class="text-xs text-text-secondary">Heat oil in a wok over high heat</span></div>
      <div class="flex items-start gap-2"><span class="text-xs font-bold text-sage">2.</span><span class="text-xs text-text-secondary">Stir-fry chicken &amp; tofu until golden</span></div>
      <div class="flex items-start gap-2"><span class="text-xs font-bold text-sage">3.</span><span class="text-xs text-text-secondary">Add vegetables and sauce, toss to combine</span></div>
      <div class="flex items-start gap-2"><span class="text-xs font-bold text-sage">4.</span><span class="text-xs text-text-secondary">Serve — see each partner's plate below</span></div>
    </div>
  </div>

  <div class="p-4">
    <p class="text-xs font-semibold text-text-primary mb-3">AI plating guide:</p>
    <div class="grid grid-cols-2 gap-3">
      <div class="rounded-xl border-2 border-sage p-3">
        <div class="flex items-center gap-2 mb-2">
          <div class="w-3 h-3 rounded-full bg-sage"></div>
          <span class="text-xs font-semibold text-sage-dark">Alex</span>
        </div>
        <div class="space-y-1 mb-2">
          <p class="text-xs text-text-secondary">6oz chicken · ½ cup rice</p>
          <p class="text-xs text-text-secondary">Bed of spinach</p>
        </div>
        <div class="pt-2 border-t border-border grid grid-cols-3 gap-1 text-center">
          <div><p class="text-xs font-bold text-sage-dark">52g</p><p class="text-[10px] text-text-secondary">Pro</p></div>
          <div><p class="text-xs font-bold text-sage-dark">75g</p><p class="text-[10px] text-text-secondary">Carb</p></div>
          <div><p class="text-xs font-bold text-sage-dark">15g</p><p class="text-[10px] text-text-secondary">Fat</p></div>
        </div>
        <p class="text-xs text-sage font-semibold mt-2 text-center">~700 cal · Muscle gain</p>
      </div>

      <div class="rounded-xl border-2 border-terracotta p-3">
        <div class="flex items-center gap-2 mb-2">
          <div class="w-3 h-3 rounded-full bg-terracotta"></div>
          <span class="text-xs font-semibold text-terracotta-dark">Jordan</span>
        </div>
        <div class="space-y-1 mb-2">
          <p class="text-xs text-text-secondary">Tofu · ¾ cup rice</p>
          <p class="text-xs text-text-secondary">Extra vegetables</p>
        </div>
        <div class="pt-2 border-t border-border grid grid-cols-3 gap-1 text-center">
          <div><p class="text-xs font-bold text-terracotta-dark">28g</p><p class="text-[10px] text-text-secondary">Pro</p></div>
          <div><p class="text-xs font-bold text-terracotta-dark">55g</p><p class="text-[10px] text-text-secondary">Carb</p></div>
          <div><p class="text-xs font-bold text-terracotta-dark">12g</p><p class="text-[10px] text-text-secondary">Fat</p></div>
        </div>
        <p class="text-xs text-terracotta-dark font-semibold mt-2 text-center">~430 cal · Weight loss</p>
      </div>
    </div>
  </div>

  <div class="px-4 py-3 border-t border-border flex items-center justify-center">
    <span class="text-xs text-text-secondary">Same pan. Different plates. Both goals hit.</span>
  </div>
</div>
