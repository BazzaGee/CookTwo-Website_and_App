---
interface Props {
  src: string;
  alt: string;
  class?: string;
}
const { src, alt, class: cls = '' } = Astro.props;
---

<div class={`phone-frame ${cls}`}>
  <div class="phone-frame__screen">
    <img src={src} alt={alt} loading="lazy" decoding="async" />
  </div>
</div>

<style>
  .phone-frame {
    position: relative;
    width: 100%;
    max-width: 280px;
    margin: 0 auto;
    border-radius: 2.5rem;
    background: #1a1a1a;
    padding: 0.5rem;
    box-shadow: 0 25px 60px -15px rgba(44, 62, 45, 0.35), 0 0 0 2px rgba(0,0,0,0.05);
  }
  .phone-frame__screen {
    position: relative;
    width: 100%;
    aspect-ratio: 9 / 19.5;
    border-radius: 2rem;
    overflow: hidden;
    background: #FAF6EE;
  }
  .phone-frame__screen img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
    display: block;
  }
  @media (min-width: 768px) {
    .phone-frame { max-width: 300px; }
  }
</style>
