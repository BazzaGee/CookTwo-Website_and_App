---
interface Props { appName?: string }
const { appName = 'CookTwo' } = Astro.props;
---

<div class="bg-white rounded-2xl border border-border overflow-hidden shadow-sm">
  <div class="px-4 py-3 border-b border-border flex items-center justify-between">
    <div class="flex items-center gap-2">
      <div class="w-6 h-6 rounded-lg bg-sage"></div>
      <span class="text-sm font-semibold text-text-primary">{appName}</span>
    </div>
    <span class="text-xs text-text-secondary">This Week</span>
  </div>

  <div class="px-4 py-2 border-b border-border flex items-center gap-3">
    <div class="flex items-center gap-1.5"><div class="w-3 h-3 rounded-full bg-sage"></div><span class="text-xs text-sage-dark">Alex · gain</span></div>
    <div class="flex items-center gap-1.5"><div class="w-3 h-3 rounded-full bg-terracotta"></div><span class="text-xs text-terracotta-dark">Jordan · lose</span></div>
  </div>

  <div class="p-4 space-y-2">
    <div class="rounded-xl border border-border p-3">
      <div class="flex items-center justify-between mb-1">
        <span class="text-xs font-semibold text-text-primary">Monday</span>
        <span class="text-xs text-sage bg-sage/10 px-2 py-0.5 rounded-full">In pantry</span>
      </div>
      <p class="text-sm text-text-primary">Chicken &amp; Tofu Stir-Fry</p>
      <p class="text-xs text-text-secondary">25 min · Both goals met</p>
    </div>
    <div class="rounded-xl border border-border p-3">
      <div class="flex items-center justify-between mb-1">
        <span class="text-xs font-semibold text-text-primary">Tuesday</span>
        <span class="text-xs text-terracotta-dark bg-terracotta/10 px-2 py-0.5 rounded-full">2 missing</span>
      </div>
      <p class="text-sm text-text-primary">Salmon &amp; Roasted Vegetables</p>
      <p class="text-xs text-text-secondary">35 min · Both goals met</p>
    </div>
    <div class="rounded-xl border border-border p-3">
      <div class="flex items-center justify-between mb-1">
        <span class="text-xs font-semibold text-text-primary">Wednesday</span>
        <span class="text-xs text-sage bg-sage/10 px-2 py-0.5 rounded-full">In pantry</span>
      </div>
      <p class="text-sm text-text-primary">Spinach &amp; Lentil Bowl</p>
      <p class="text-xs text-text-secondary">20 min · Both goals met</p>
    </div>
    <div class="rounded-xl border border-border p-3">
      <div class="flex items-center justify-between mb-1">
        <span class="text-xs font-semibold text-text-primary">Thursday</span>
        <span class="text-xs text-terracotta-dark bg-terracotta/10 px-2 py-0.5 rounded-full">3 missing</span>
      </div>
      <p class="text-sm text-text-primary">Chicken Tacos &amp; Avocado</p>
      <p class="text-xs text-text-secondary">30 min · Both goals met</p>
    </div>
    <div class="rounded-xl border border-border p-3">
      <div class="flex items-center justify-between mb-1">
        <span class="text-xs font-semibold text-text-primary">Friday</span>
        <span class="text-xs text-sage bg-sage/10 px-2 py-0.5 rounded-full">In pantry</span>
      </div>
      <p class="text-sm text-text-primary">Coconut Chickpea Curry</p>
      <p class="text-xs text-text-secondary">30 min · Both goals met</p>
    </div>
  </div>

  <div class="px-4 py-3 border-t border-border flex items-center justify-between">
    <span class="text-xs font-semibold text-text-primary">Add 5 missing to list</span>
    <span class="text-xs text-sage font-medium">Auto-categorised →</span>
  </div>
</div>
