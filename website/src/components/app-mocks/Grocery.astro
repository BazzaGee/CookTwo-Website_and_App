---
interface Props { appName?: string }
const { appName = 'CookTwo' } = Astro.props;
---

<div class="bg-white rounded-2xl border border-border overflow-hidden shadow-sm">
  <div class="px-4 py-3 border-b border-border flex items-center justify-between">
    <div class="flex items-center gap-2">
      <div class="w-6 h-6 rounded-lg bg-sage"></div>
      <span class="text-sm font-semibold text-text-primary">{appName}</span>
    </div>
    <span class="text-xs text-text-secondary">Our Shopping List</span>
  </div>

  <div class="px-4 py-3 border-b border-border">
    <div class="flex items-center gap-2">
      <div class="flex-1 px-3 py-2 rounded-lg border border-border text-xs text-text-secondary">milk, bread, chicken, dish soap…</div>
      <div class="px-3 py-2 rounded-lg bg-sage text-white text-xs font-medium">Add</div>
    </div>
    <div class="flex flex-wrap gap-1.5 mt-2">
      <span class="text-xs px-2 py-1 rounded-full border border-border text-text-secondary">Milk</span>
      <span class="text-xs px-2 py-1 rounded-full border border-border text-text-secondary">Eggs</span>
      <span class="text-xs px-2 py-1 rounded-full border border-border text-text-secondary">Bread</span>
      <span class="text-xs px-2 py-1 rounded-full border border-border text-text-secondary">Chicken</span>
      <span class="text-xs px-2 py-1 rounded-full border border-border text-text-secondary">Rice</span>
    </div>
  </div>

  <div class="p-4">
    <p class="text-xs font-semibold text-text-primary mb-3">To buy (5 items):</p>
    <div class="space-y-2">
      <div class="flex items-center justify-between py-2 px-3 rounded-lg border border-l-4 border-l-sage">
        <div class="flex items-center gap-3">
          <div class="w-4 h-4 rounded border-2 border-border"></div>
          <div>
            <p class="text-sm text-text-primary">Whole Milk</p>
            <p class="text-xs text-text-secondary">Dairy · 1 litre</p>
          </div>
        </div>
        <div class="flex items-center gap-1"><div class="w-4 h-4 rounded-full bg-sage"></div><span class="text-xs text-sage-dark">Alex</span></div>
      </div>
      <div class="flex items-center justify-between py-2 px-3 rounded-lg border border-l-4 border-l-terracotta">
        <div class="flex items-center gap-3">
          <div class="w-4 h-4 rounded border-2 border-border"></div>
          <div>
            <p class="text-sm text-text-primary">Chicken Breast</p>
            <p class="text-xs text-text-secondary">Meat · 500g</p>
          </div>
        </div>
        <div class="flex items-center gap-1"><div class="w-4 h-4 rounded-full bg-terracotta"></div><span class="text-xs text-terracotta-dark">Jordan</span></div>
      </div>
      <div class="flex items-center justify-between py-2 px-3 rounded-lg border border-l-4 border-l-sage">
        <div class="flex items-center gap-3">
          <div class="w-4 h-4 rounded border-2 border-border"></div>
          <div>
            <p class="text-sm text-text-primary">Baby Spinach</p>
            <p class="text-xs text-text-secondary">Produce · 1 bag</p>
          </div>
        </div>
        <div class="flex items-center gap-1"><div class="w-4 h-4 rounded-full bg-sage"></div><span class="text-xs text-sage-dark">Alex</span></div>
      </div>
      <div class="flex items-center justify-between py-2 px-3 rounded-lg border border-l-4 border-l-terracotta">
        <div class="flex items-center gap-3">
          <div class="w-4 h-4 rounded border-2 border-border"></div>
          <div>
            <p class="text-sm text-text-primary">Jasmine Rice</p>
            <p class="text-xs text-text-secondary">Pantry · 1 kg</p>
          </div>
        </div>
        <div class="flex items-center gap-1"><div class="w-4 h-4 rounded-full bg-terracotta"></div><span class="text-xs text-terracotta-dark">Jordan</span></div>
      </div>
      <div class="flex items-center justify-between py-2 px-3 rounded-lg opacity-60">
        <div class="flex items-center gap-3">
          <div class="w-4 h-4 rounded bg-sage flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3"><path d="m9 11 3 3L22 4"/></svg>
          </div>
          <div>
            <p class="text-sm line-through text-text-secondary">Eggs</p>
            <p class="text-xs text-text-secondary">Dairy · 1 dozen</p>
          </div>
        </div>
        <span class="text-xs text-sage font-medium">Move to Pantry</span>
      </div>
    </div>
  </div>

  <div class="px-4 py-3 border-t border-border flex items-center justify-between">
    <span class="text-xs text-text-secondary">5 items · synced just now</span>
    <span class="text-xs text-sage font-medium flex items-center gap-1">
      <span class="w-1.5 h-1.5 rounded-full bg-sage animate-pulse"></span> Live
    </span>
  </div>
</div>
