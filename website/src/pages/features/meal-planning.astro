---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PhoneFrame from '../../components/app-mocks/PhoneFrame.astro';
---

<BaseLayout title="AI Meal Planning — CookTwo" description="From 'what's for dinner?' to dinner in 5 minutes. Conversational AI creates personalized weekly meal plans for couples with different dietary goals.">
  <section class="section-padding">
    <div class="container-custom">
      <div class="max-w-3xl mx-auto text-center">
        <span class="badge-live mb-4 inline-block">Live Feature</span>
        <h1 class="text-4xl md:text-6xl font-bold text-text-primary mb-6">From "what's for dinner?"<br/>to dinner in 5 minutes.</h1>
        <p class="text-xl text-text-secondary leading-relaxed">
          Chat with AI to plan your week's meals. It knows your pantry, your partner's goals, your preferences — and creates personalized plans for both of you.
        </p>
      </div>
    </div>
  </section>

  <section class="pb-16">
    <div class="container-custom">
      <div class="flex flex-col md:flex-row items-center justify-center gap-8">
        <PhoneFrame src="/images/app/03b-meal-card.webp" alt="CookTwo AI-generated meal card with ingredients, steps and dual plating" class="max-w-[240px]" />
        <div class="max-w-sm">
          <p class="text-sm font-semibold text-sage uppercase tracking-wider mb-2">The live app</p>
          <p class="text-text-secondary leading-relaxed">One tap generates a meal that respects both diets and both goals — then plates it two ways. Ask for tweaks in plain English, save the wins, and add anything missing straight to the list.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="pb-20">
    <div class="container-custom">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
        <div>
          <h2 class="text-2xl md:text-3xl font-bold text-text-primary mb-6">Conversational Meal Planning</h2>
          <p class="text-text-secondary leading-relaxed mb-6">
            No rigid forms or dropdowns. Just tell the AI what you're in the mood for, what you have, or what your week looks like. It handles the rest.
          </p>

          <div class="space-y-4 mb-8">
            <div class="flex items-start gap-3">
              <div class="w-8 h-8 rounded-lg bg-sage/10 flex items-center justify-center text-sage flex-shrink-0 mt-0.5">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              </div>
              <div>
                <p class="font-semibold text-text-primary">Session Memory</p>
                <p class="text-sm text-text-secondary">The AI remembers your conversation. Build on previous suggestions, adjust portions, swap ingredients — all in context.</p>
              </div>
            </div>

            <div class="flex items-start gap-3">
              <div class="w-8 h-8 rounded-lg bg-sage/10 flex items-center justify-center text-sage flex-shrink-0 mt-0.5">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              </div>
              <div>
                <p class="font-semibold text-text-primary">Pantry-Aware</p>
                <p class="text-sm text-text-secondary">AI checks what you already have and prioritizes recipes using those ingredients. Less waste, smarter planning.</p>
              </div>
            </div>

            <div class="flex items-start gap-3">
              <div class="w-8 h-8 rounded-lg bg-sage/10 flex items-center justify-center text-sage flex-shrink-0 mt-0.5">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              </div>
              <div>
                <p class="font-semibold text-text-primary">Adaptive for Both</p>
                <p class="text-sm text-text-secondary">Every meal plan includes portion adjustments for both partners based on their individual TDEE and goals.</p>
              </div>
            </div>
          </div>
        </div>

        <div class="card p-0 overflow-hidden">
          <div class="bg-sage p-4">
            <div class="flex items-center gap-2">
              <div class="w-3 h-3 rounded-full bg-white/30"></div>
              <div class="w-3 h-3 rounded-full bg-white/30"></div>
              <div class="w-3 h-3 rounded-full bg-white/30"></div>
              <span class="ml-2 text-sm text-white/80 font-medium">Tonight's Dinner</span>
            </div>
          </div>

          <div class="p-5 space-y-4 max-h-[400px] overflow-y-auto">
            <div class="flex items-start gap-3">
              <div class="w-8 h-8 rounded-full bg-sage/10 flex items-center justify-center flex-shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-sage"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
              </div>
              <div class="bg-cream rounded-xl rounded-tl-sm p-3 max-w-[85%]">
                <p class="text-sm text-text-primary">We have chicken and rice. Something Asian-inspired, not too heavy. I'm trying to cut and Alex is bulking.</p>
              </div>
            </div>

            <div class="flex items-start gap-3 flex-row-reverse">
              <div class="w-8 h-8 rounded-full bg-sage flex items-center justify-center flex-shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-white"><path d="M12 2a10 10 0 1 0 10 10"/><path d="M12 12l7-7"/><circle cx="12" cy="12" r="3"/></svg>
              </div>
              <div class="bg-sage/10 rounded-xl rounded-tr-sm p-3 max-w-[85%]">
                <p class="text-sm text-text-primary mb-2 font-medium">Teriyaki Chicken Stir-Fry</p>
                <p class="text-xs text-text-secondary mb-2">Perfect for your pantry! Here's how it adapts:</p>
                <div class="grid grid-cols-2 gap-2 mb-2">
                  <div class="bg-white rounded-lg p-2 text-center">
                    <p class="text-xs font-semibold text-sage">Your plate</p>
                    <p class="text-sm font-bold text-text-primary">~420 cal</p>
                    <p class="text-[10px] text-text-secondary">35g P · 38g C · 16g F</p>
                  </div>
                  <div class="bg-white rounded-lg p-2 text-center">
                    <p class="text-xs font-semibold text-terracotta">Alex's plate</p>
                    <p class="text-sm font-bold text-text-primary">~680 cal</p>
                    <p class="text-[10px] text-text-secondary">52g P · 62g C · 26g F</p>
                  </div>
                </div>
                <p class="text-xs text-text-secondary">Want me to add this to your weekly plan?</p>
              </div>
            </div>

            <div class="flex items-start gap-3">
              <div class="w-8 h-8 rounded-full bg-sage/10 flex items-center justify-center flex-shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-sage"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
              </div>
              <div class="bg-cream rounded-xl rounded-tl-sm p-3 max-w-[85%]">
                <p class="text-sm text-text-primary">Yes! And can you suggest lunches for the week using what we have?</p>
              </div>
            </div>

            <div class="flex items-start gap-3 flex-row-reverse">
              <div class="w-8 h-8 rounded-full bg-sage flex items-center justify-center flex-shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-white"><path d="M12 2a10 10 0 1 0 10 10"/><path d="M12 12l7-7"/><circle cx="12" cy="12" r="3"/></svg>
              </div>
              <div class="bg-sage/10 rounded-xl rounded-tr-sm p-3 max-w-[85%]">
                <p class="text-sm text-text-primary">Done! I've created a 5-day lunch plan using your chicken, rice, and veggies. Added the missing items to your shared grocery list. Check your <span class="font-semibold text-sage">Week</span> tab to see it all.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section-padding bg-cream-dark">
    <div class="container-custom">
      <div class="text-center max-w-2xl mx-auto mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-text-primary mb-4">Three Views. One Plan.</h2>
        <p class="text-lg text-text-secondary">Navigate your meals the way that works for you.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-4xl mx-auto">
        <div class="card text-center">
          <div class="w-14 h-14 rounded-2xl bg-sage/10 flex items-center justify-center text-sage mx-auto mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
          </div>
          <h3 class="font-bold text-text-primary text-lg mb-2">Tonight</h3>
          <p class="text-sm text-text-secondary leading-relaxed">The AI chat interface. Tell it what you're craving and get instant, personalized dinner suggestions for both partners.</p>
        </div>

        <div class="card text-center">
          <div class="w-14 h-14 rounded-2xl bg-terracotta/10 flex items-center justify-center text-terracotta mx-auto mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21l-7-5-7 5V5a2 2 0 012-2h10a2 2 0 012 2z"/></svg>
          </div>
          <h3 class="font-bold text-text-primary text-lg mb-2">Saved</h3>
          <p class="text-sm text-text-secondary leading-relaxed">Your recipe library. Save meals you loved, with portion presets for both partners already baked in.</p>
        </div>

        <div class="card text-center">
          <div class="w-14 h-14 rounded-2xl bg-sage/10 flex items-center justify-center text-sage mx-auto mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          </div>
          <h3 class="font-bold text-text-primary text-lg mb-2">Week</h3>
          <p class="text-sm text-text-secondary leading-relaxed">Your 7-day meal plan. See every meal at a glance, adjust servings, and auto-generate the grocery list for the week.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section-padding">
    <div class="container-custom">
      <div class="text-center max-w-2xl mx-auto mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-text-primary mb-4">Multi-Provider AI Chain</h2>
        <p class="text-lg text-text-secondary">Always-on AI with automatic fallback.</p>
      </div>

      <div class="max-w-2xl mx-auto">
        <div class="card">
          <div class="flex items-center justify-between mb-6">
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 rounded-xl bg-sage/10 flex items-center justify-center">
                <span class="text-lg">🧠</span>
              </div>
              <div>
                <p class="font-bold text-text-primary">DeepSeek</p>
                <p class="text-xs text-sage">Primary</p>
              </div>
            </div>
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-sage"><polyline points="9 18 15 12 9 6"/></svg>
          </div>

          <div class="border-l-2 border-dashed border-sage/20 ml-5 pl-8 pb-4 mb-4">
            <div class="flex items-center gap-3 mb-4">
              <div class="w-10 h-10 rounded-xl bg-terracotta/10 flex items-center justify-center">
                <span class="text-lg">🤖</span>
              </div>
              <div>
                <p class="font-bold text-text-primary">Alibaba Qwen</p>
                <p class="text-xs text-terracotta">Fallback #1</p>
              </div>
            </div>
          </div>

          <div class="border-l-2 border-dashed border-terracotta/20 ml-5 pl-8">
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 rounded-xl bg-sage/10 flex items-center justify-center">
                <span class="text-lg">⚡</span>
              </div>
              <div>
                <p class="font-bold text-text-primary">ZAI</p>
                <p class="text-xs text-text-secondary">Fallback #2</p>
              </div>
            </div>
          </div>

          <p class="mt-6 text-sm text-text-secondary leading-relaxed">
            If the primary provider is slow or unavailable, CookTwo automatically falls back to the next in the chain. You never wait or see an error.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="section-padding bg-cream-dark">
    <div class="container-custom">
      <div class="text-center max-w-2xl mx-auto mb-8">
        <h2 class="text-3xl md:text-4xl font-bold text-text-primary mb-4">AI Meal Photography</h2>
        <p class="text-lg text-text-secondary">Every recipe gets a beautiful, AI-generated photo using the Alibaba Wan 2.6 model.</p>
      </div>

      <div class="max-w-md mx-auto card text-center">
        <div class="w-full h-48 bg-gradient-to-br from-sage/20 to-terracotta/20 rounded-xl flex items-center justify-center mb-4">
          <div class="text-center">
            <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-sage/50 mx-auto mb-2"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
            <p class="text-sm text-text-secondary">AI-generated meal photo</p>
            <p class="text-xs text-text-secondary">Alibaba Wan 2.6</p>
          </div>
        </div>
        <p class="text-sm text-text-secondary">No more blank recipe cards. Every meal gets a appetizing visual, generated instantly by AI.</p>
      </div>
    </div>
  </section>

  <section class="section-padding">
    <div class="container-custom text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-text-primary mb-4">Start Planning Tonight</h2>
      <p class="text-lg text-text-secondary mb-8 max-w-2xl mx-auto">
        AI meal planning that knows your pantry, your partner, and your goals. Dinner has never been easier.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="/features" class="btn-primary">All Features</a>
        <a href="/features/pantry-ai" class="btn-secondary">Pantry AI</a>
      </div>
    </div>
  </section>
</BaseLayout>
