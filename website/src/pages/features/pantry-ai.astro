---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PhoneFrame from '../../components/app-mocks/PhoneFrame.astro';

const categories = [
  { emoji: '🥗', name: 'Produce', color: 'bg-green-50 text-green-700' },
  { emoji: '🥩', name: 'Meat', color: 'bg-red-50 text-red-700' },
  { emoji: '🥛', name: 'Dairy', color: 'bg-blue-50 text-blue-700' },
  { emoji: '🫙', name: 'Pantry', color: 'bg-amber-50 text-amber-700' },
  { emoji: '🏠', name: 'Household', color: 'bg-purple-50 text-purple-700' },
  { emoji: '🧴', name: 'Personal Care', color: 'bg-pink-50 text-pink-700' },
  { emoji: '📦', name: 'Other', color: 'bg-gray-50 text-gray-700' }
];
---

<BaseLayout title="Pantry-First AI — CookTwo" description="Type what you have in natural language. CookTwo's AI parses, categorizes, and tracks your pantry to drive smarter meal suggestions.">
  <section class="section-padding">
    <div class="container-custom">
      <div class="max-w-3xl mx-auto text-center">
        <span class="badge-live mb-4 inline-block">Live Feature</span>
        <h1 class="text-4xl md:text-6xl font-bold text-text-primary mb-6">Type what you have.<br/>AI does the rest.</h1>
        <p class="text-xl text-text-secondary leading-relaxed">
          No forms. No dropdowns. Just type "chicken, 2 cups rice, spinach, half an onion" and CookTwo's AI parses every item, estimates quantities, and categorizes them automatically.
        </p>
      </div>
    </div>
  </section>

  <section class="pb-16">
    <div class="container-custom">
      <div class="flex flex-col md:flex-row items-center justify-center gap-8">
        <div class="max-w-sm order-2 md:order-1">
          <p class="text-sm font-semibold text-sage uppercase tracking-wider mb-2">The live app</p>
          <p class="text-text-secondary leading-relaxed">Type a whole shelf in one line. CookTwo parses quantities, units and categories, flags items that need review, and remembers what you have — so meals are built around food you already own.</p>
        </div>
        <PhoneFrame src="/images/app/02-pantry.webp" alt="CookTwo pantry — natural language input, AI sorting, pantry items" class="max-w-[240px] order-1 md:order-2" />
      </div>
    </div>
  </section>

  <section class="pb-20">
    <div class="container-custom">
      <div class="max-w-3xl mx-auto">
        <div class="card mb-8">
          <p class="text-sm font-semibold text-text-secondary mb-3 uppercase tracking-wider">You type</p>
          <div class="bg-cream rounded-xl p-5 mb-6">
            <p class="text-lg text-text-primary font-medium">"chicken, 2 cups rice, spinach, half an onion, 1 lb ground beef, olive oil"</p>
          </div>

          <p class="text-sm font-semibold text-text-secondary mb-3 uppercase tracking-wider">AI parses into structured items</p>

          <div class="space-y-3">
            <div class="flex items-center gap-3 bg-cream rounded-lg p-3">
              <span class="text-sm">🥩</span>
              <div class="flex-1">
                <p class="text-sm font-medium text-text-primary">Chicken</p>
                <p class="text-xs text-text-secondary">Meat · No quantity specified</p>
              </div>
              <span class="text-xs px-2 py-1 rounded-full bg-red-50 text-red-700">Meat</span>
            </div>

            <div class="flex items-center gap-3 bg-cream rounded-lg p-3">
              <span class="text-sm">🫙</span>
              <div class="flex-1">
                <p class="text-sm font-medium text-text-primary">Rice</p>
                <p class="text-xs text-text-secondary">Pantry · 2 cups</p>
              </div>
              <span class="text-xs px-2 py-1 rounded-full bg-amber-50 text-amber-700">Pantry</span>
            </div>

            <div class="flex items-center gap-3 bg-cream rounded-lg p-3">
              <span class="text-sm">🥗</span>
              <div class="flex-1">
                <p class="text-sm font-medium text-text-primary">Spinach</p>
                <p class="text-xs text-text-secondary">Produce · No quantity specified</p>
              </div>
              <span class="text-xs px-2 py-1 rounded-full bg-green-50 text-green-700">Produce</span>
            </div>

            <div class="flex items-center gap-3 bg-cream rounded-lg p-3">
              <span class="text-sm">🥗</span>
              <div class="flex-1">
                <p class="text-sm font-medium text-text-primary">Onion</p>
                <p class="text-xs text-text-secondary">Produce · 0.5 (half)</p>
              </div>
              <span class="text-xs px-2 py-1 rounded-full bg-green-50 text-green-700">Produce</span>
            </div>

            <div class="flex items-center gap-3 bg-cream rounded-lg p-3">
              <span class="text-sm">🥩</span>
              <div class="flex-1">
                <p class="text-sm font-medium text-text-primary">Ground Beef</p>
                <p class="text-xs text-text-secondary">Meat · 1 lb</p>
              </div>
              <span class="text-xs px-2 py-1 rounded-full bg-red-50 text-red-700">Meat</span>
            </div>

            <div class="flex items-center gap-3 bg-cream rounded-lg p-3">
              <span class="text-sm">🫙</span>
              <div class="flex-1">
                <p class="text-sm font-medium text-text-primary">Olive Oil</p>
                <p class="text-xs text-text-secondary">Pantry · No quantity specified</p>
              </div>
              <span class="text-xs px-2 py-1 rounded-full bg-amber-50 text-amber-700">Pantry</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section-padding bg-cream-dark">
    <div class="container-custom">
      <div class="text-center max-w-2xl mx-auto mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-text-primary mb-4">7 Smart Categories</h2>
        <p class="text-lg text-text-secondary">Every item lands in the right bucket. Always.</p>
      </div>

      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4 max-w-3xl mx-auto">
        {categories.map((cat) => (
          <div class="bg-white rounded-xl p-5 text-center border border-border hover:border-sage transition-colors">
            <span class="text-3xl block mb-2">{cat.emoji}</span>
            <p class="font-semibold text-text-primary text-sm">{cat.name}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section-padding">
    <div class="container-custom">
      <div class="text-center max-w-2xl mx-auto mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-text-primary mb-4">Pantry to Meal Flow</h2>
        <p class="text-lg text-text-secondary">Your pantry doesn't just sit there. It actively drives better meal suggestions.</p>
      </div>

      <div class="max-w-3xl mx-auto">
        <div class="relative">
          <div class="absolute left-6 top-0 bottom-0 w-0.5 bg-sage/20 hidden md:block"></div>

          <div class="space-y-8">
            <div class="flex items-start gap-6">
              <div class="w-12 h-12 rounded-full bg-sage/10 flex items-center justify-center text-sage flex-shrink-0 relative z-10 border-4 border-cream">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
              </div>
              <div class="flex-1 pt-1">
                <h3 class="font-bold text-text-primary text-lg mb-1">1. Tell CookTwo what you have</h3>
                <p class="text-text-secondary">Type naturally: "we have chicken, rice, some veggies, soy sauce" — AI parses everything.</p>
              </div>
            </div>

            <div class="flex items-start gap-6">
              <div class="w-12 h-12 rounded-full bg-sage/10 flex items-center justify-center text-sage flex-shrink-0 relative z-10 border-4 border-cream">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
              </div>
              <div class="flex-1 pt-1">
                <h3 class="font-bold text-text-primary text-lg mb-1">2. AI categorizes and stores</h3>
                <p class="text-text-secondary">Each item gets sorted into the right category with estimated quantities. Your pantry builds itself.</p>
              </div>
            </div>

            <div class="flex items-start gap-6">
              <div class="w-12 h-12 rounded-full bg-sage/10 flex items-center justify-center text-sage flex-shrink-0 relative z-10 border-4 border-cream">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
              </div>
              <div class="flex-1 pt-1">
                <h3 class="font-bold text-text-primary text-lg mb-1">3. Smarter meal suggestions</h3>
                <p class="text-text-secondary">Meal plans prioritize recipes using what you already have. Less waste, fewer grocery trips, better planning.</p>
              </div>
            </div>

            <div class="flex items-start gap-6">
              <div class="w-12 h-12 rounded-full bg-sage/10 flex items-center justify-center text-sage flex-shrink-0 relative z-10 border-4 border-cream">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
              </div>
              <div class="flex-1 pt-1">
                <h3 class="font-bold text-text-primary text-lg mb-1">4. Auto-generate grocery list</h3>
                <p class="text-text-secondary">Missing ingredients for your meal plan? CookTwo auto-creates a grocery list with what you need — synced to both phones.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section-padding bg-cream-dark">
    <div class="container-custom text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-text-primary mb-4">Pantry-Powered Planning</h2>
      <p class="text-lg text-text-secondary mb-8 max-w-2xl mx-auto">
        Your pantry connects to every feature. Smarter meals, less waste, synced grocery lists.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="/features/adaptive-cooking" class="btn-primary">Adaptive Cooking</a>
        <a href="/features/shared-grocery-list" class="btn-secondary">Shared Grocery List</a>
      </div>
    </div>
  </section>
</BaseLayout>
