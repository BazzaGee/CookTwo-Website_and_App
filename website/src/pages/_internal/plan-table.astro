---
// Temporary page to screenshot the plan comparison table
---

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Plan Comparison</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Inter', system-ui, sans-serif; background: #FAF6EE; color: #2C3E2D; padding: 40px; width: 800px; }
    .table-wrap { max-width: 700px; margin: 0 auto; }
    h2 { font-size: 24px; font-weight: 700; margin-bottom: 8px; }
    .subtitle { font-size: 14px; color: #6B7B6C; margin-bottom: 24px; }
    table { width: 100%; border-collapse: collapse; }
    th { text-align: left; font-size: 13px; font-weight: 600; color: #6B7B6C; padding: 12px 16px; border-bottom: 2px solid #E5E1DA; }
    th:not(:first-child) { text-align: center; }
    td { padding: 14px 16px; border-bottom: 1px solid #E5E1DA; font-size: 14px; }
    td:not(:first-child) { text-align: center; }
    td:first-child { font-weight: 500; }
    .plan-free { color: #6B7B6C; font-weight: 600; }
    .plan-premium { color: #7A9E7E; font-weight: 600; }
    .check { color: #7A9E7E; font-size: 18px; }
    .dash { color: #E5E1DA; }
    .price-row td { border-bottom: none; padding-top: 20px; }
    .price { font-weight: 700; font-size: 15px; }
    .price-free { color: #6B7B6C; }
    .price-premium { color: #7A9E7E; }
    .price-sub { font-size: 12px; color: #6B7B6C; display: block; margin-top: 2px; }
  </style>
</head>
<body>
  <div class="table-wrap">
    <h2>Free vs Premium</h2>
    <p class="subtitle">Both plans are full-featured. The difference is how much AI you get per day.</p>
    <table>
      <thead>
        <tr>
          <th></th>
          <th><span class="plan-free">Free</span></th>
          <th><span class="plan-premium">Premium</span></th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td>AI requests per day</td>
          <td>10</td>
          <td>70</td>
        </tr>
        <tr>
          <td>Chat with the meal planner</td>
          <td><span class="check">✓</span></td>
          <td><span class="check">✓</span></td>
        </tr>
        <tr>
          <td>Generate dinners</td>
          <td><span class="check">✓</span></td>
          <td><span class="check">✓</span></td>
        </tr>
        <tr>
          <td>Save unlimited recipes</td>
          <td><span class="check">✓</span></td>
          <td><span class="check">✓</span></td>
        </tr>
        <tr>
          <td>Real-time sync</td>
          <td><span class="check">✓</span></td>
          <td><span class="check">✓</span></td>
        </tr>
        <tr>
          <td>Adaptive plating for two</td>
          <td><span class="check">✓</span></td>
          <td><span class="check">✓</span></td>
        </tr>
        <tr>
          <td>Priority AI responses</td>
          <td><span class="dash">—</span></td>
          <td><span class="check">✓</span></td>
        </tr>
        <tr class="price-row">
          <td></td>
          <td><span class="price price-free">Free</span></td>
          <td>
            <span class="price price-premium">$4.99/mo</span>
            <span class="price-sub">or $44.99/yr (save 25%)</span>
          </td>
        </tr>
      </tbody>
    </table>
  </div>
</body>
</html>
