---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 | CookTwo" description="Page not found.">
  <section class="section-padding">
    <div class="container-custom text-center">
      <div class="max-w-lg mx-auto">
        <div class="text-8xl font-bold text-sage/20 mb-6">404</div>
        <h1 class="text-3xl font-bold tracking-tight mb-4">Page Not Found</h1>
        <p class="text-lg text-text-secondary mb-8">Looks like this page went to the grocery store and never came back.</p>
        <a href="/" class="btn-primary inline-block">Back to Homepage</a>
      </div>
    </div>
  </section>
</BaseLayout>
