    background: #fff;
    color: #6B7B6C;
    transition: all 0.2s;
    cursor: pointer;
  }
  .plate-tab:hover { border-color: #7A9E7E; color: #5A7E5E; }
  .plate-tab.active { background: #7A9E7E; border-color: #7A9E7E; color: #fff; box-shadow: 0 4px 12px -4px rgba(122,158,126,0.5); }

