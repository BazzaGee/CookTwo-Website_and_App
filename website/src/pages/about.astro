<script>
  // ---- Count-up animation ----
  const counters = document.querySelectorAll('.count-up');
  const animateCount = (el) => {
    const target = parseInt(el.dataset.target, 10);
    const dur = 1200;
    const start = performance.now();
    const step = (now) => {
      const p = Math.min((now - start) / dur, 1);
      const eased = 1 - Math.pow(1 - p, 3);
      el.textContent = Math.round(target * eased).toString();
      if (p < 1) requestAnimationFrame(step);
    };
    requestAnimationFrame(step);
  };
  const io = new IntersectionObserver((entries) => {
    entries.forEach((e) => {
      if (e.isIntersecting) { animateCount(e.target); io.unobserve(e.target); }
    });
  }, { threshold: 0.4 });
  counters.forEach((c) => io.observe(c));

  // ---- Audience tabs ----
  document.querySelectorAll('[data-tabs]').forEach((group) => {
    const tabs = group.querySelectorAll('.audience-tab');
    const panels = group.querySelectorAll('.audience-panel');
    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        const id = tab.dataset.tab;
        tabs.forEach((t) => {
          const on = t === tab;
          t.setAttribute('aria-selected', on ? 'true' : 'false');
          t.classList.toggle('bg-sage', on);
          t.classList.toggle('text-white', on);
          t.classList.toggle('border-sage', on);
          t.classList.toggle('shadow-sm', on);
          t.classList.toggle('bg-white', !on);
          t.classList.toggle('text-text-secondary', !on);
          t.classList.toggle('border-border', !on);
        });
        panels.forEach((p) => p.classList.toggle('hidden', p.dataset.panel !== id));
      });
    });
  });

  // ---- Plate toggle ----
  const plates = {
    a: { name: 'Alex', initial: 'A', goal: 'Goal · Weight loss (20% deficit)', cal: '450 cal', p: 35, c: 30, f: 18, pPct: 70, cPct: 45, fPct: 30, method: 'Calculated via Mifflin-St Jeor TDEE with a 20% calorie deficit.', accent: '#7A9E7E', bar: 'sage' },
    b: { name: 'Jordan', initial: 'B', goal: 'Goal · Muscle gain (15% surplus)', cal: '700 cal', p: 55, c: 65, f: 28, pPct: 92, cPct: 75, fPct: 50, method: 'Calculated via Mifflin-St Jeor TDEE with a 15% calorie surplus.', accent: '#E8A87C', bar: 'terra' }
  };
  const plateTabs = document.querySelectorAll('.plate-tab');
  const setPlate = (key) => {
    const d = plates[key];
    const card = document.getElementById('plate-card');
    card.style.borderColor = d.accent;
    document.getElementById('plate-name').textContent = d.name;
    document.getElementById('plate-goal').textContent = d.goal;
    document.getElementById('plate-cal').textContent = d.cal;
    document.getElementById('plate-cal').style.color = d.accent;
    const av = document.getElementById('plate-avatar');
    av.textContent = d.initial;
    av.style.background = d.accent;
    document.getElementById('val-p').textContent = d.p + 'g';
    document.getElementById('val-c').textContent = d.c + 'g';
    document.getElementById('val-f').textContent = d.f + 'g';
    const bp = document.getElementById('bar-p'), bc = document.getElementById('bar-c'), bf = document.getElementById('bar-f');
    bp.style.width = d.pPct + '%'; bc.style.width = d.cPct + '%'; bf.style.width = d.fPct + '%';
    [bp, bc, bf].forEach((b, i) => {
      b.style.background = d.bar === 'sage'
        ? ['#7A9E7E', '#9ABE9E', '#BfD6Bf'][i]
        : ['#E8A87C', '#F0B489', '#F8C89C'][i];
    });
    document.getElementById('plate-method').textContent = d.method;
    plateTabs.forEach((t) => t.classList.toggle('active', t.dataset.plate === key));
  };
  plateTabs.forEach((t) => t.addEventListener('click', () => setPlate(t.dataset.plate)));

  // ---- FAQ accordion ----
  document.querySelectorAll('.faq-trigger').forEach((btn) => {
    btn.addEventListener('click', () => {
      const panel = btn.nextElementSibling;
      const isOpen = !panel.classList.contains('hidden');
      btn.setAttribute('aria-expanded', isOpen ? 'false' : 'true');
      panel.classList.toggle('hidden');
      if (!isOpen) { panel.classList.add('pb-5'); }
    });
  });
</script>
