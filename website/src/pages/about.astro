---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'About CookTwo — The Cooking App Built for Two | Couples Meal Planning';
const description = 'CookTwo is a collaborative adaptive nutrition app for couples. Learn what CookTwo is, who it\'s for, how it works (one meal, two personalized plates), and how it ends the nightly "what\'s for dinner?" argument.';

// ---- FAQ data (drives UI + FAQPage schema) ----
const faqs = [
  { q: 'What is CookTwo?', a: 'CookTwo is a collaborative, adaptive nutrition app built for two people who share one kitchen. You and your partner get one shared pantry, one shared grocery list, and AI-generated meals — with each person receiving a personalized portion and macro split from the same recipe.' },
  { q: 'Who is CookTwo for?', a: 'Couples and two-person households where the partners have different dietary goals — one losing weight while the other builds muscle, a vegetarian paired with an omnivore, or simply two busy people who want to stop wasting food and arguing about dinner.' },
  { q: 'How does CookTwo personalize portions for each partner?', a: 'Each partner enters their body metrics (weight, height, age, gender, activity level) and a goal. CookTwo calculates daily energy needs with the Mifflin-St Jeor TDEE equation, applies a deficit or surplus, then splits the same recipe into two plates with different calories, protein, carbs, and fat.' },
  { q: 'Do both partners need the app installed?', a: 'Yes. One person creates the kitchen and shares a 6-digit invite code; the partner enters it from their own device. Both profiles then sync to the same household in real time over a WebSocket connection.' },
  { q: 'Does CookTwo work offline?', a: 'Yes. CookTwo is an installable PWA. Grocery and pantry changes are queued locally when the connection drops and sync automatically the moment you reconnect — so you can keep shopping in a dead-zone aisle.' },
  { q: 'How much does CookTwo cost?', a: 'CookTwo is free during beta with no credit card required. The Pro tier is $4.99 and unlocks higher AI meal limits and priority generation.' },
  { q: 'Is CookTwo a meal-kit delivery service?', a: 'No. CookTwo plans around the food you already own and adds only what\'s missing to a shared shopping list. There are no weekly boxes, shipping fees, or subscriptions to a delivery service.' },
  { q: 'What diets and goals does CookTwo support?', a: 'Vegetarian, vegan, keto, paleo and gluten-free preferences, plus common allergies, and goals spanning weight loss, maintenance, muscle gain, or simply "just eat well".' }
];

const audiences = [
  { id: 'goals', icon: 'scale', title: 'Different-goal couples', tag: 'Most common', desc: 'One partner is cutting while the other is bulking. Cook one meal, plate it two ways — no second pan, no separate plans.', points: ['TDEE-based portions per partner', 'Same recipe, different calories', 'Macro split for each plate'] },
  { id: 'diets', icon: 'leaf', title: 'Mixed diets & allergies', tag: 'Adaptive', desc: 'A vegetarian and an omnivore. Keto meets balanced. CookTwo respects both profiles in one shared plan.', points: ['Vegetarian, vegan, keto, paleo, gluten-free', 'Allergy-aware meal generation', 'One plan, two dietary lanes'] },
  { id: 'busy', icon: 'clock', title: 'Busy households', tag: 'Time-saver', desc: 'Two schedules, one pantry. Pantry-aware AI and a live shared list turn planning into seconds.', points: ['Meals built from what you own', 'Real-time shared grocery list', 'Set up once, cook every day'] },
  { id: 'budget', icon: 'piggy', title: 'Budget-conscious cooks', tag: 'Saves money', desc: 'Stop duplicate buys, impulse delivery, and good food going bad. Cook from your pantry first.', points: ['Cuts duplicate groceries', 'Reduces food waste', 'Fewer delivery orders'] }
];

const features = [
  { href: '/features/adaptive-cooking', badge: 'Signature Feature', badgeClass: 'badge-signature', title: 'Adaptive Shared Cooking', desc: 'One recipe becomes two personalized plates with portions and macros calculated from each partner\'s TDEE and goal.', icon: 'chef' },
  { href: '/features/shared-grocery-list', badge: 'Live', badgeClass: 'badge-live', title: 'Real-Time Shared Grocery List', desc: 'Add milk at home — it appears on your partner\'s phone at the store in under 100ms via WebSocket sync.', icon: 'basket' },
  { href: '/features/pantry-ai', badge: 'Live', badgeClass: 'badge-live', title: 'Pantry-First AI', desc: 'Type "chicken, rice, spinach." The AI parses natural language, categorizes items, and suggests meals you can cook right now.', icon: 'boxes' },
  { href: '/features/meal-planning', badge: 'Live', badgeClass: 'badge-live', title: 'AI Meal Planning', desc: 'Chat with AI to plan tonight\'s dinner from your pantry — or auto-add what\'s missing to your shared list.', icon: 'calendar' },
  { href: '/features/real-time-sync', badge: 'Infrastructure', badgeClass: 'badge-live', title: 'Real-Time Sync & Offline', desc: 'Per-household WebSockets, an offline queue, and a PWA you install like a native app. Works in any aisle.', icon: 'wifi' }
];

const differentiators = [
  { cap: 'One shared kitchen for two', tracker: false, recipe: false, kit: 'partial', ct: true },
  { cap: 'Two goals from one recipe', tracker: false, recipe: false, kit: false, ct: true },
  { cap: 'Personalized portions per partner', tracker: 'partial', recipe: false, kit: false, ct: true },
  { cap: 'Real-time shared grocery list', tracker: false, recipe: 'partial', kit: false, ct: true },
  { cap: 'Shared pantry with AI sorting', tracker: false, recipe: false, kit: false, ct: true },
  { cap: 'Pantry-first meal suggestions', tracker: false, recipe: 'partial', kit: false, ct: true },
  { cap: 'Cuts duplicate groceries & waste', tracker: false, recipe: false, kit: 'partial', ct: true },
  { cap: 'Installable app + offline', tracker: 'partial', recipe: 'partial', kit: false, ct: true },
  { cap: 'No weekly box or shipping fees', tracker: true, recipe: true, kit: false, ct: true }
];

const cellData = (v) => {
  if (v === true) return { sym: '✓', cls: 'text-sage font-bold' };
  if (v === 'partial') return { sym: 'Partial', cls: 'text-terracotta font-medium text-xs' };
  return { sym: '✕', cls: 'text-terracotta/50 font-bold' };
};

const stats = [
  { value: 2, suffix: '', label: 'people, one shared kitchen', sub: 'profiles that cook together' },
  { value: 100, suffix: 'ms', label: 'real-time sync ceiling', sub: 'add milk, partner sees it instantly' },
  { value: 5, suffix: '', label: 'steps from setup to dinner', sub: 'about two minutes to configure' },
  { value: 7, suffix: '', label: 'auto grocery categories', sub: 'Produce to Frozen, sorted by AI' }
];

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://cooktwo.com/" },
    { "@type": "ListItem", "position": 2, "name": "About", "item": "https://cooktwo.com/about/" }
  ]
};

const aboutPageSchema = {
  "@context": "https://schema.org",
  "@type": "AboutPage",
  "name": "About CookTwo",
  "url": "https://cooktwo.com/about/",
  "description": "CookTwo is a collaborative adaptive nutrition app for couples — one shared kitchen, one meal plated two ways.",
  "mainEntity": {
    "@type": "SoftwareApplication",
    "name": "CookTwo",
    "applicationCategory": "LifestyleApplication",
    "operatingSystem": "Web, iOS, Android (PWA)",
    "description": "Collaborative adaptive nutrition app for couples. AI meal planning, shared grocery list, shared pantry, and personalized portions per partner.",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD", "description": "Free during beta; Pro tier $4.99" },
    "featureList": [
      "Adaptive shared cooking — one recipe, two personalized plates",
      "Real-time shared grocery list with sub-100ms sync",
      "Pantry-first AI with natural-language input",
      "AI meal planning from pantry or shopping list",
      "Offline-capable installable PWA"
    ]
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(f => ({
    "@type": "Question",
    "name": f.q,
    "acceptedAnswer": { "@type": "Answer", "text": f.a }
  }))
};
---

<BaseLayout title={title} description={description} canonicalURL="/about/" ogImage="/images/pages/about/og-about.webp">

<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)}></script>
<script type="application/ld+json" set:html={JSON.stringify(aboutPageSchema)}></script>
<script type="application/ld+json" set:html={JSON.stringify(faqSchema)}></script>

  <!-- ============ STICKY SECTION NAV ============ -->
  <nav aria-label="On this page" class="sticky top-20 z-30 bg-cream/85 backdrop-blur-md border-b border-border">
    <div class="container-custom">
      <ul class="flex items-center gap-1 overflow-x-auto py-3 text-sm font-medium no-scrollbar">
        <li class="text-text-secondary/70 whitespace-nowrap pr-2 hidden sm:block">On this page:</li>
        <li><a href="#what" class="whitespace-nowrap px-3 py-1.5 rounded-lg text-text-secondary hover:text-sage hover:bg-sage/5 transition-colors">What is CookTwo</a></li>
        <li><a href="#why" class="whitespace-nowrap px-3 py-1.5 rounded-lg text-text-secondary hover:text-sage hover:bg-sage/5 transition-colors">Why it exists</a></li>
        <li><a href="#who" class="whitespace-nowrap px-3 py-1.5 rounded-lg text-text-secondary hover:text-sage hover:bg-sage/5 transition-colors">Who it's for</a></li>
        <li><a href="#how" class="whitespace-nowrap px-3 py-1.5 rounded-lg text-text-secondary hover:text-sage hover:bg-sage/5 transition-colors">How it works</a></li>
        <li><a href="#signature" class="whitespace-nowrap px-3 py-1.5 rounded-lg text-text-secondary hover:text-sage hover:bg-sage/5 transition-colors">Adaptive plating</a></li>
        <li><a href="#features" class="whitespace-nowrap px-3 py-1.5 rounded-lg text-text-secondary hover:text-sage hover:bg-sage/5 transition-colors">Features</a></li>
        <li><a href="#compare" class="whitespace-nowrap px-3 py-1.5 rounded-lg text-text-secondary hover:text-sage hover:bg-sage/5 transition-colors">How it's different</a></li>
        <li><a href="#faq" class="whitespace-nowrap px-3 py-1.5 rounded-lg text-text-secondary hover:text-sage hover:bg-sage/5 transition-colors">FAQ</a></li>
      </ul>
    </div>
  </nav>

  <!-- ============ HERO ============ -->
  <section class="section-padding bg-cream relative overflow-hidden">
    <div class="absolute inset-0 opacity-40 pointer-events-none">
      <div class="absolute top-16 left-8 w-72 h-72 bg-sage/20 rounded-full blur-3xl"></div>
      <div class="absolute bottom-8 right-8 w-96 h-96 bg-terracotta/15 rounded-full blur-3xl"></div>
    </div>
    <div class="container-custom relative z-10">
      <div class="max-w-3xl mx-auto text-center mb-12">
        <span class="badge-signature mb-6 inline-block">About CookTwo</span>
        <h1 class="text-4xl md:text-6xl font-bold text-text-primary mb-6 leading-tight">The cooking app <span class="text-sage">built for two.</span></h1>
        <p class="text-xl md:text-2xl text-text-secondary leading-relaxed">CookTwo is a collaborative, adaptive nutrition app. One shared kitchen, one meal — plated two different ways, so couples with different goals never have to cook separately again.</p>
      </div>
      <figure class="max-w-5xl mx-auto rounded-3xl overflow-hidden shadow-2xl border border-border bg-white">
        <img src="/images/pages/about/product-showcase.webp" alt="CookTwo app screens showing the shared grocery list, pantry-first AI, and adaptive meal plating for two partners" class="w-full" width="1600" height="1000" fetchpriority="high" decoding="async" />
        <figcaption class="bg-white px-6 py-4 text-center text-sm text-text-secondary border-t border-border">Real CookTwo screens — the shared shopping list, AI-sorted pantry, and one Chicken Stir-Fry plated two ways for partners Alex &amp; Jordan.</figcaption>
      </figure>
    </div>
  </section>

  <!-- ============ KEY STATS ============ -->
  <section class="py-12 md:py-16 bg-white border-y border-border">
    <div class="container-custom">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 md:gap-8">
        {stats.map((s) => (
          <div class="text-center">
            <div class="text-4xl md:text-5xl font-bold text-sage tracking-tight">
              <span class="count-up" data-target={s.value}>0</span><span class="text-terracotta">{s.suffix}</span>
            </div>
            <p class="text-sm font-semibold text-text-primary mt-2">{s.label}</p>
            <p class="text-xs text-text-secondary mt-1">{s.sub}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ WHAT IS COOKTWO ============ -->
  <section id="what" class="section-padding bg-cream">
    <div class="container-custom">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <div>
          <span class="badge-live mb-6 inline-block">What is CookTwo?</span>
          <h2 class="text-3xl md:text-4xl font-bold text-text-primary mb-6">A shared kitchen that lives on both your phones</h2>
          <p class="text-lg text-text-secondary leading-relaxed mb-6">Most cooking apps are built for one person tracking one diet. CookTwo is different: it links <strong class="text-text-primary">two profiles to one household</strong> — a shared pantry, a shared grocery list, and an AI that plans meals around what you already own <em>and</em> what each of you is trying to achieve.</p>
          <p class="text-lg text-text-secondary leading-relaxed mb-8">The result is a single dinner, cooked once, that arrives on two differently-sized plates — each with the calories and macros that partner needs. No second meal. No separate plans. No nightly argument.</p>
          <div class="grid grid-cols-2 gap-4">
            <div class="bg-white rounded-xl border border-border p-5">
              <div class="flex items-center gap-2 mb-2">
                <span class="w-2.5 h-2.5 rounded-full bg-sage"></span>
                <p class="font-bold text-text-primary text-sm">One kitchen</p>
              </div>
              <p class="text-sm text-text-secondary">Pantry, grocery list &amp; meal plan shared in real time.</p>
            </div>
            <div class="bg-white rounded-xl border border-border p-5">
              <div class="flex items-center gap-2 mb-2">
                <span class="w-2.5 h-2.5 rounded-full bg-terracotta"></span>
                <p class="font-bold text-text-primary text-sm">Two plates</p>
              </div>
              <p class="text-sm text-text-secondary">Same recipe, personalized portions &amp; macros each.</p>
            </div>
          </div>
        </div>
        <div class="bg-white rounded-2xl border border-border shadow-lg p-8">
          <h3 class="text-xl font-bold text-text-primary mb-5 flex items-center gap-2">
            <svg class="w-5 h-5 text-sage" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
            CookTwo at a glance
          </h3>
          <dl class="divide-y divide-border">
            <div class="flex justify-between gap-4 py-3"><dt class="text-text-secondary text-sm">Category</dt><dd class="font-semibold text-text-primary text-sm text-right">Collaborative adaptive nutrition</dd></div>
            <div class="flex justify-between gap-4 py-3"><dt class="text-text-secondary text-sm">Built for</dt><dd class="font-semibold text-text-primary text-sm text-right">Couples &amp; two-person households</dd></div>
            <div class="flex justify-between gap-4 py-3"><dt class="text-text-secondary text-sm">Core promise</dt><dd class="font-semibold text-text-primary text-sm text-right">One meal, two personalized plates</dd></div>
            <div class="flex justify-between gap-4 py-3"><dt class="text-text-secondary text-sm">Platform</dt><dd class="font-semibold text-text-primary text-sm text-right">Installable PWA (iOS &amp; Android)</dd></div>
            <div class="flex justify-between gap-4 py-3"><dt class="text-text-secondary text-sm">Sync</dt><dd class="font-semibold text-text-primary text-sm text-right">Real-time, sub-100ms, offline-ready</dd></div>
            <div class="flex justify-between gap-4 py-3"><dt class="text-text-secondary text-sm">Price</dt><dd class="font-semibold text-text-primary text-sm text-right">Free in beta · Pro $4.99</dd></div>
          </dl>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ WHY IT EXISTS ============ -->
  <section id="why" class="section-padding bg-cream-dark">
    <div class="container-custom">
      <div class="text-center mb-12 max-w-2xl mx-auto">
        <span class="badge-signature mb-4 inline-block">Why CookTwo exists</span>
        <h2 class="text-3xl md:text-5xl font-bold text-text-primary mb-4">Every couple knows these struggles</h2>
        <p class="text-xl text-text-secondary">CookTwo was created to end the nightly "what's for dinner?" loop — the duplicate groceries, wasted food, and separate meals when two people eat differently.</p>
      </div>
      <figure class="max-w-4xl mx-auto rounded-3xl overflow-hidden shadow-xl border border-border bg-white mb-12">
        <img src="/images/pages/about/why-exists.webp" alt="Infographic: common couple cooking struggles without CookTwo versus how CookTwo solves them, including food waste and decision fatigue statistics" class="w-full" width="1200" height="1400" loading="lazy" decoding="async" />
        <figcaption class="px-6 py-4 text-center text-sm text-text-secondary border-t border-border">The problem CookTwo solves — duplicate groceries, wasted food, and cooking two separate meals for different goals.</figcaption>
      </figure>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-4xl mx-auto">
        <div class="bg-white rounded-2xl border border-border p-6 md:p-8">
          <div class="flex items-center gap-2 mb-4">
            <span class="w-8 h-8 rounded-full bg-error/10 flex items-center justify-center">
              <svg class="w-4 h-4 text-error" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
            </span>
            <h3 class="text-xl font-bold text-text-primary">The old way</h3>
          </div>
          <ul class="space-y-3 text-text-secondary text-sm">
            <li class="flex items-start gap-2"><span class="text-error mt-1">•</span><span>The nightly "what should we eat?" back-and-forth that ends in takeout</span></li>
            <li class="flex items-start gap-2"><span class="text-error mt-1">•</span><span>Cooking two separate meals when partners have different goals</span></li>
            <li class="flex items-start gap-2"><span class="text-error mt-1">•</span><span>Duplicate groceries and good food going bad in the fridge</span></li>
            <li class="flex items-start gap-2"><span class="text-error mt-1">•</span><span>20 minutes scrolling delivery apps instead of cooking</span></li>
          </ul>
        </div>
        <div class="bg-white rounded-2xl border-2 border-sage p-6 md:p-8 shadow-sm">
          <div class="flex items-center gap-2 mb-4">
            <span class="w-8 h-8 rounded-full bg-sage/15 flex items-center justify-center">
              <svg class="w-4 h-4 text-sage" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            </span>
            <h3 class="text-xl font-bold text-text-primary">The CookTwo way</h3>
          </div>
          <ul class="space-y-3 text-text-secondary text-sm">
            <li class="flex items-start gap-2"><span class="text-sage mt-1">•</span><span>AI suggests dinner in seconds from your pantry &amp; both goals</span></li>
            <li class="flex items-start gap-2"><span class="text-sage mt-1">•</span><span>One recipe, two plates — different portions, same pan</span></li>
            <li class="flex items-start gap-2"><span class="text-sage mt-1">•</span><span>A single live list means zero duplicates, far less waste</span></li>
            <li class="flex items-start gap-2"><span class="text-sage mt-1">•</span><span>Use what you own before it expires — cook first, deliver less</span></li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ WHO IT'S FOR ============ -->
  <section id="who" class="section-padding bg-white">
    <div class="container-custom">
      <div class="text-center mb-12 max-w-2xl mx-auto">
        <span class="badge-live mb-4 inline-block">Who it's for</span>
        <h2 class="text-3xl md:text-5xl font-bold text-text-primary mb-4">Made for two people, one kitchen</h2>
        <p class="text-xl text-text-secondary">If you and someone else share meals and groceries — but not always the same goals — CookTwo was built for you. Tap a profile to see how it fits.</p>
      </div>

      <figure class="max-w-4xl mx-auto rounded-3xl overflow-hidden shadow-xl border border-border bg-cream mb-12">
        <img src="/images/pages/about/who-its-for.webp" alt="Infographic: who CookTwo is for — different-goal couples, mixed diets, busy households, budget-conscious cooks, health-focused pairs and new cooks" class="w-full" width="1200" height="1280" loading="lazy" decoding="async" />
        <figcaption class="px-6 py-4 text-center text-sm text-text-secondary border-t border-border">Six types of two-person households CookTwo is designed for.</figcaption>
      </figure>

      <!-- Interactive audience tabs -->
      <div class="max-w-4xl mx-auto" data-tabs>
        <div class="flex flex-wrap justify-center gap-2 mb-8" role="tablist" aria-label="Audience types">
          {audiences.map((a, i) => (
            <button role="tab" data-tab={a.id} aria-selected={i === 0 ? 'true' : 'false'} class={`audience-tab px-4 py-2.5 rounded-xl text-sm font-semibold transition-all border ${i === 0 ? 'bg-sage text-white border-sage shadow-sm' : 'bg-white text-text-secondary border-border hover:border-sage hover:text-sage'}`}>{a.title}</button>
          ))}
        </div>
        {audiences.map((a, i) => (
          <div data-panel={a.id} class={`audience-panel bg-cream rounded-2xl border border-border p-6 md:p-10 ${i === 0 ? '' : 'hidden'}`}>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8 items-center">
              <div class="md:col-span-2">
                <span class={`inline-block text-xs px-2.5 py-1 rounded-full font-medium mb-3 ${a.id === 'goals' || a.id === 'busy' ? 'bg-sage/10 text-sage' : 'bg-terracotta/10 text-terracotta'}`}>{a.tag}</span>
                <h3 class="text-2xl font-bold text-text-primary mb-3">{a.title}</h3>
                <p class="text-text-secondary leading-relaxed mb-5">{a.desc}</p>
                <ul class="space-y-2.5">
                  {a.points.map((p) => (
                    <li class="flex items-start gap-3 text-text-secondary">
                      <svg class="w-5 h-5 mt-0.5 text-sage flex-shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                      <span>{p}</span>
                    </li>
                  ))}
                </ul>
              </div>
              <div class="bg-white rounded-2xl border border-border p-6 text-center">
                <p class="text-5xl font-bold text-sage mb-1">1</p>
                <p class="text-sm text-text-secondary mb-3">recipe</p>
                <div class="flex items-center justify-center gap-2 text-text-secondary my-3">
                  <svg class="w-5 h-5 text-sage" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                </div>
                <p class="text-5xl font-bold text-terracotta mb-1">2</p>
                <p class="text-sm text-text-secondary">personalized plates</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ HOW IT WORKS ============ -->
  <section id="how" class="section-padding bg-cream">
    <div class="container-custom">
      <div class="text-center mb-12 max-w-2xl mx-auto">
        <span class="badge-signature mb-4 inline-block">How CookTwo works</span>
        <h2 class="text-3xl md:text-5xl font-bold text-text-primary mb-4">Set up once. Cook every day.</h2>
        <p class="text-xl text-text-secondary">A two-minute setup links you and your partner to one shared kitchen. Then a self-reinforcing loop runs every single day.</p>
      </div>
      <figure class="max-w-4xl mx-auto rounded-3xl overflow-hidden shadow-xl border border-border bg-white mb-12">
        <img src="/images/pages/about/how-it-works.webp" alt="Infographic: the CookTwo flow — two-minute setup across five steps, then a daily loop of pantry, AI meal suggestions, shopping list and cooking two plates" class="w-full" width="1200" height="1500" loading="lazy" decoding="async" />
