---
import BaseLayout from './BaseLayout.astro';
import EarlyAccessButton from '../components/forms/EarlyAccessButton.astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  author?: string;
  ogImage?: string;
  canonicalURL?: string;
  pillar?: string;
  readingTime?: string;
  tags?: string[];
}

const { title, description, pubDate, updatedDate, author = 'CookTwo', ogImage, canonicalURL, pillar, readingTime, tags = [] } = Astro.props;

const formattedDate = pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
const formattedUpdated = updatedDate?.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<BaseLayout title={`${title} | CookTwo`} description={description} ogImage={ogImage} canonicalURL={canonicalURL}>
  <article class="container-custom max-w-3xl py-12 md:py-20">
    {pillar && (
      <a href={`/blog?pillar=${encodeURIComponent(pillar)}`} class="inline-block text-sm font-medium text-sage hover:text-sage-dark mb-4 transition-colors">
        ← {pillar}
      </a>
    )}
    <header class="mb-10">
      <h1 class="text-4xl md:text-5xl font-bold tracking-tight text-text-primary leading-tight mb-4">{title}</h1>
      <p class="text-xl text-text-secondary leading-relaxed mb-6">{description}</p>
      <div class="flex flex-wrap items-center gap-3 text-sm text-text-secondary">
        <span>{author}</span>
        <span aria-hidden="true">·</span>
        <time datetime={pubDate.toISOString()}>{formattedDate}</time>
        {readingTime && (
          <>
            <span aria-hidden="true">·</span>
            <span>{readingTime}</span>
          </>
        )}
        {updatedDate && (
          <>
            <span aria-hidden="true">·</span>
            <span>Updated {formattedUpdated}</span>
          </>
        )}
      </div>
      {tags.length > 0 && (
        <div class="mt-4 flex flex-wrap gap-2">
          {tags.map((t) => (
            <span class="text-xs px-3 py-1 rounded-full bg-cream-dark text-text-secondary border border-border">{t}</span>
          ))}
        </div>
      )}
    </header>

    <div class="prose prose-lg max-w-none
      prose-headings:tracking-tight prose-headings:text-text-primary
      prose-h2:text-3xl prose-h2:mt-12 prose-h2:mb-4
      prose-h3:text-2xl prose-h3:mt-8 prose-h3:mb-3
      prose-p:text-text-primary prose-p:leading-relaxed
      prose-a:text-sage prose-a:no-underline hover:prose-a:underline
      prose-strong:text-text-primary
      prose-li:text-text-primary
      prose-img:rounded-2xl prose-img:shadow-sm
      prose-blockquote:border-sage prose-blockquote:text-text-secondary
    ">
      <slot />
    </div>

    <footer class="mt-16 pt-8 border-t border-border">
      <div class="bg-cream-dark rounded-2xl p-8 text-center">
        <p class="text-lg text-text-primary font-medium mb-2">One dinner. Two plates. Zero arguments.</p>
        <p class="text-text-secondary mb-6">Try the shared food system for couples.</p>
        <EarlyAccessButton label="Get early access" variant="primary" />
      </div>
    </footer>
  </article>
</BaseLayout>
