---
import BaseLayout from './BaseLayout.astro';
import EarlyAccessButton from '../components/forms/EarlyAccessButton.astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  author?: string;
  ogImage?: string;
  canonicalURL?: string;
  pillar?: string;
  pageType?: 'pillar' | 'vs' | 'guide';
  relatedPosts?: { slug: string; title: string }[];
  tags?: string[];
}

const { title, description, pubDate, updatedDate, author = 'CookTwo', ogImage, canonicalURL, pillar, pageType = 'pillar', relatedPosts = [], tags = [] } = Astro.props;

const formattedDate = pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
const formattedUpdated = updatedDate?.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<BaseLayout title={title} description={description} ogImage={ogImage} canonicalURL={canonicalURL} isArticle={true} articlePublishedDate={pubDate.toISOString()} articleAuthor={author} articleTags={tags}>
  <article class="container-custom max-w-4xl py-12 md:py-20">
    {pillar && pageType === 'vs' && (
      <a href="/compare" class="inline-block text-sm font-medium text-sage hover:text-sage-dark mb-4 transition-colors">← Compare</a>
    )}
    {pillar && pageType !== 'vs' && (
      <a href={`/blog?pillar=${encodeURIComponent(pillar)}`} class="inline-block text-sm font-medium text-sage hover:text-sage-dark mb-4 transition-colors">
        ← {pillar}
      </a>
    )}
    <header class="mb-12">
      {pageType === 'vs' && (
        <span class="badge-signature mb-4 inline-block">Comparison</span>
      )}
      {pageType === 'guide' && (
        <span class="badge-live mb-4 inline-block">Guide</span>
      )}
      <h1 class="text-4xl md:text-6xl font-bold tracking-tight text-text-primary leading-tight mb-6">{title}</h1>
      <p class="text-xl md:text-2xl text-text-secondary leading-relaxed mb-8">{description}</p>
      <div class="flex flex-wrap items-center gap-3 text-sm text-text-secondary">
        <span>{author}</span>
        <span aria-hidden="true">·</span>
        <time datetime={pubDate.toISOString()}>{formattedDate}</time>
        {updatedDate && (
          <>
            <span aria-hidden="true">·</span>
            <span>Updated {formattedUpdated}</span>
          </>
        )}
      </div>
      {tags.length > 0 && (
        <div class="mt-4 flex flex-wrap gap-2">
          {tags.map((t) => (
            <span class="text-xs px-3 py-1 rounded-full bg-cream-dark text-text-secondary border border-border">{t}</span>
          ))}
        </div>
      )}
    </header>

    <div class="prose prose-xl max-w-none
      prose-headings:tracking-tight prose-headings:text-text-primary
      prose-h2:text-3xl prose-h2:mt-16 prose-h2:mb-6
      prose-h3:text-2xl prose-h3:mt-10 prose-h3:mb-4
      prose-p:text-text-primary prose-p:leading-relaxed
      prose-a:text-sage prose-a:no-underline hover:prose-a:underline
      prose-strong:text-text-primary
      prose-li:text-text-primary
      prose-img:rounded-2xl prose-img:shadow-sm
      prose-blockquote:border-sage prose-blockquote:text-text-secondary
    ">
      <slot />
    </div>

    {relatedPosts.length > 0 && (
      <section class="mt-20 pt-12 border-t border-border">
        <h2 class="text-2xl font-bold text-text-primary mb-6">Related reading</h2>
        <div class="grid sm:grid-cols-2 gap-4">
          {relatedPosts.map((post) => (
            <a href={`/blog/${post.slug}`} class="card group">
              <h3 class="text-lg font-semibold text-text-primary group-hover:text-sage transition-colors">{post.title}</h3>
            </a>
          ))}
        </div>
      </section>
    )}

    {pageType !== 'guide' && (
      <footer class="mt-16 pt-8 border-t border-border">
        <div class="bg-cream-dark rounded-2xl p-8 text-center">
          <p class="text-lg text-text-primary font-medium mb-2">One dinner. Two plates. Zero arguments.</p>
          <p class="text-text-secondary mb-6">Try the shared food system for couples.</p>
          <EarlyAccessButton label="Get early access" variant="primary" />
        </div>
      </footer>
    )}
  </article>
</BaseLayout>
