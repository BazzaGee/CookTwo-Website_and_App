---
// src/pages/app/settings.astro
import AppLayout from '../../layouts/AppLayout.astro';

export const prerender = false;
---

<AppLayout>
  <div class="p-6 max-w-3xl mx-auto">
    <h1 class="text-2xl font-bold text-slate-900 mb-6">Settings</h1>
    
    <!-- Profile Section -->
    <div class="bg-white rounded-xl p-6 shadow-sm border border-slate-200 mb-6">
      <h2 class="text-lg font-semibold mb-4">Profile</h2>
      <div class="space-y-4">
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1">Full Name</label>
          <input type="text" id="profile-name" class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-rose-500 outline-none">
        </div>
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1">Email</label>
          <input type="email" id="profile-email" disabled class="w-full px-4 py-2 border rounded-lg bg-slate-100">
        </div>
        <button id="save-profile-btn" class="px-4 py-2 bg-rose-500 text-white rounded-lg hover:bg-rose-600 transition">
          Save Changes
        </button>
      </div>
    </div>
    
    <!-- Calendar Connections -->
    <div class="bg-white rounded-xl p-6 shadow-sm border border-slate-200 mb-6">
      <h2 class="text-lg font-semibold mb-4">Calendar Connections</h2>
      <p class="text-sm text-slate-600 mb-4">Connect your calendars to sync events</p>
      
      <div id="calendar-connections" class="space-y-3">
        <div class="flex items-center justify-between p-3 border rounded-lg">
          <div class="flex items-center gap-3">
            <svg class="w-6 h-6" viewBox="0 0 24 24">
              <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
              <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
              <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
              <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
            </svg>
            <div>
              <p class="font-medium">Google Calendar</p>
              <p id="google-status" class="text-sm text-slate-500">Not connected</p>
            </div>
          </div>
          <button id="connect-google-btn" class="px-4 py-2 bg-rose-500 text-white rounded-lg hover:bg-rose-600 transition text-sm">
            Connect
          </button>
        </div>
        
        <div class="flex items-center justify-between p-3 border rounded-lg">
          <div class="flex items-center gap-3">
            <svg class="w-6 h-6 text-blue-600" fill="currentColor" viewBox="0 0 24 24">
              <path d="M21.17 3.25Q21.5 3.25 21.76 3.5 22 3.74 22 4.08V19.92Q22 20.26 21.76 20.5 21.5 20.75 21.17 20.75H7.83Q7.5 20.75 7.24 20.5 7 20.26 7 19.92V17H2.83Q2.5 17 2.24 16.76 2 16.5 2 16.17V7.83Q2 7.5 2.24 7.24 2.5 7 2.83 7H7V4.08Q7 3.74 7.24 3.5 7.5 3.25 7.83 3.25M7 13.06L8.18 15.28Q8.27 15.5 8.5 15.5H9.19Q9.5 15.5 9.5 15.19V13.06H11.5V15.19Q11.5 15.5 11.81 15.5H13.19Q13.5 15.5 13.5 15.19V13.06H15.5V15.19Q15.5 15.5 15.81 15.5H17.19Q17.5 15.5 17.5 15.19V13.06H19.5V15.19Q19.5 15.5 19.81 15.5H20.5V16.25H7V13.06M7 9.5H19.5V11.5H7V9.5Z"/>
            </svg>
            <div>
              <p class="font-medium">Outlook Calendar</p>
              <p id="outlook-status" class="text-sm text-slate-500">Not connected</p>
            </div>
          </div>
          <button id="connect-outlook-btn" class="px-4 py-2 bg-rose-500 text-white rounded-lg hover:bg-rose-600 transition text-sm">
            Connect
          </button>
        </div>
      </div>
    </div>
    
    <!-- Date Goal -->
    <div class="bg-white rounded-xl p-6 shadow-sm border border-slate-200 mb-6">
      <h2 class="text-lg font-semibold mb-4">Date Frequency Goal</h2>
      <div class="flex items-center gap-4">
        <span class="text-slate-600">We want to go on a date every:</span>
        <select id="date-frequency" class="px-4 py-2 border rounded-lg focus:ring-2 focus:ring-rose-500 outline-none">
          <option value="weekly">Week</option>
          <option value="biweekly">2 Weeks</option>
          <option value="monthly">Month</option>
        </select>
        <button id="save-frequency-btn" class="px-4 py-2 bg-rose-500 text-white rounded-lg hover:bg-rose-600 transition">
          Save
        </button>
      </div>
    </div>
    
    <!-- Danger Zone -->
    <div class="bg-red-50 rounded-xl p-6 border border-red-200">
      <h2 class="text-lg font-semibold text-red-700 mb-4">Danger Zone</h2>
      <div class="space-y-3">
        <div class="flex items-center justify-between">
          <div>
            <p class="font-medium text-slate-900">Unlink Partner</p>
            <p class="text-sm text-slate-600">Remove your partner connection</p>
          </div>
          <button id="unlink-btn" class="px-4 py-2 border border-red-300 text-red-600 rounded-lg hover:bg-red-100 transition">
            Unlink
          </button>
        </div>
      </div>
    </div>
  </div>

  <script>
    import { supabase } from '../../lib/supabase/client';
    
    let userId;
    
    async function init() {
      const { data: { user } } = await supabase.auth.getUser();
      if (!user) return;
      
      userId = user.id;
      
      // Load profile
      const { data: profile } = await supabase
        .from('profiles')
        .select('*')
        .eq('id', user.id)
        .single();
      
      if (profile) {
        document.getElementById('profile-name').value = profile.full_name || '';
        document.getElementById('profile-email').value = profile.email;
        if (profile.date_frequency_goal) {
          document.getElementById('date-frequency').value = profile.date_frequency_goal;
        }
      }
      
      // Load calendar connections
      await loadCalendarConnections();
    }
    
    async function loadCalendarConnections() {
      const { data: connections } = await supabase
        .from('calendar_connections')
        .select('provider')
        .eq('user_id', userId);
      
      const hasGoogle = connections?.some(c => c.provider === 'google');
      const hasOutlook = connections?.some(c => c.provider === 'outlook');
      
      document.getElementById('google-status').textContent = hasGoogle ? 'Connected' : 'Not connected';
      document.getElementById('google-status').className = hasGoogle ? 'text-sm text-green-600' : 'text-sm text-slate-500';
      
      document.getElementById('outlook-status').textContent = hasOutlook ? 'Connected' : 'Not connected';
      document.getElementById('outlook-status').className = hasOutlook ? 'text-sm text-green-600' : 'text-sm text-slate-500';
    }
    
    // Save profile
    document.getElementById('save-profile-btn')?.addEventListener('click', async () => {
      const name = document.getElementById('profile-name').value;
      
      await supabase
        .from('profiles')
        .update({ full_name: name })
        .eq('id', userId);
      
      alert('Profile updated!');
    });
    
    // Save date frequency
    document.getElementById('save-frequency-btn')?.addEventListener('click', async () => {
      const frequency = document.getElementById('date-frequency').value;
      
      await supabase
        .from('profiles')
        .update({ date_frequency_goal: frequency })
        .eq('id', userId);
      
      alert('Date frequency goal saved!');
    });
    
    // Connect Google
    document.getElementById('connect-google-btn')?.addEventListener('click', () => {
      // Redirect to Google OAuth flow
      const clientId = import.meta.env.PUBLIC_GOOGLE_CLIENT_ID;
      const redirectUri = `${window.location.origin}/api/calendar/callback`;
      const scope = 'https://www.googleapis.com/auth/calendar.readonly https://www.googleapis.com/auth/calendar.events';
      
      const url = `https://accounts.google.com/o/oauth2/v2/auth?client_id=${clientId}&redirect_uri=${redirectUri}&response_type=code&scope=${encodeURIComponent(scope)}&access_type=offline&prompt=consent`;
      window.location.href = url;
    });
    
    // Connect Outlook
    document.getElementById('connect-outlook-btn')?.addEventListener('click', () => {
      const clientId = import.meta.env.PUBLIC_MICROSOFT_CLIENT_ID;
      const redirectUri = `${window.location.origin}/api/calendar/callback`;
      const scope = 'Calendars.Read Calendars.ReadWrite offline_access';
      
      const url = `https://login.microsoftonline.com/common/oauth2/v2.0/authorize?client_id=${clientId}&response_type=code&redirect_uri=${redirectUri}&scope=${encodeURIComponent(scope)}`;
      window.location.href = url;
    });
    
    // Unlink partner
    document.getElementById('unlink-btn')?.addEventListener('click', async () => {
      if (!confirm('Are you sure? This will remove your partner connection.')) return;
      
      await supabase
        .from('profiles')
        .update({ partner_id: null })
        .eq('id', userId);
      
      window.location.href = '/auth/pair';
    });
    
    init();
  </script>
</AppLayout>
